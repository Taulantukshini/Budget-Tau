let FAVORITES = JSON.parse(localStorage.getItem('tau_favorites') || '[]');
function saveFavorites() { localStorage.setItem('tau_favorites', JSON.stringify(FAVORITES)); }

function renderFavorites() {
  const strip = document.getElementById('fav-strip');
  if (!strip) return;
  const catColors = getCatColors();
