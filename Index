const KEYWORDS={'Alimentation':['migros','coop','lidl','aldi','manor','denner','volg','spar','carrefour','restaurant','cafe','bistro','mcdo','burger','pizza','sushi','lunch','dinner'],'Transport':['esso','bp','shell','tamoil','agip','essence','parking','autoroute','sbb','cff','tpg','bus','tram','taxi','uber'],'Abonnements':['netflix','spotify','apple','google','amazon','disney','icloud','gym','fitness','abonnement'],'Santé/Beauté':['pharmacie','medecin','dentiste','hopital','coiffeur','salon','beaute','optique'],'Loisirs':['cinema','concert','fnac','livre','loisir'],'Logement':['loyer','credit','electricite','internet','swisscom'],'Voyage':['hotel','airbnb','booking','flixbus','easyjet','swiss','airport'],};
function detectCategory(filename){
  const txt=filename.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g,'');
  for(const[cat,words]of Object.entries(KEYWORDS)){if(words.some(w=>txt.includes(w)))return cat;}
  return null;
}
function scanReceipt(input,prefix){
  if(!input.files||!input.files[0])return;
  const file=input.files[0];
  const preview=document.getElementById(prefix+'-scan-preview');
  const img=document.getElementById(prefix+'-scan-img');
  const lbl=document.getElementById(prefix+'-scan-label');
  const result=document.getElementById(prefix+'-scan-result');
  const reader=new FileReader();
  reader.onload=(e)=>{
    img.src=e.target.result;preview.style.display='block';
    const detectedCat=detectCategory(file.name||'');
    const d=new Date(file.lastModified||Date.now());
    const detectedDate=d.toISOString().split('T')[0];
    document.getElementById(prefix+'-date').value=detectedDate;
    const y=d.getFullYear(),m=d.getMonth();
    const mi=MF.findIndex(mf=>mf.toLowerCase().includes(String(y))&&mf.toLowerCase().includes(MNAMES[m]));
    if(mi>=0)document.getElementById(prefix+'-month').value=mi;
    if(detectedCat&&CATS[detectedCat])document.getElementById(prefix+'-cat').value=detectedCat;
    const cleanName=file.name.replace(/\.[^.]+$/,'').replace(/[_\-]/g,' ').replace(/IMG|DSC|PHOTO|\d{8}|\d{6}/gi,'').trim();
    if(cleanName.length>2&&cleanName.length<40)document.getElementById(prefix+'-desc').value=cleanName;
    lbl.textContent='📷 Photo chargée';
    result.style.display='block';
    result.innerHTML=`Photo chargée${detectedCat?' · Catégorie suggérée : <strong>'+detectedCat+'</strong>':''} · Saisis le montant`;
    document.getElementById(prefix+'-amount').focus();
  };
  reader.readAsDataURL(file);
}

