// ── BUDGET MONTH MANAGEMENT ──
const MONTH_NAMES_FR = ['Janvier','Février','Mars','Avril','Mai','Juin','Juillet','Août','Septembre','Octobre','Novembre','Décembre'];

function getNextMonth() {
  const last = MF[MF.length - 1];
  const parts = last.split(' ');
  const mName = parts[0], year = parseInt(parts[1]);
  const mIdx = MONTH_NAMES_FR.indexOf(mName);
  const nextIdx = (mIdx + 1) % 12;
  const nextYear = nextIdx === 0 ? year + 1 : year;
  return MONTH_NAMES_FR[nextIdx] + ' ' + nextYear;
}

function addBudgetMonth() {
  const next = getNextMonth();
  if (MF.includes(next)) { showFB('Ce mois existe déjà', 'var(--amber)'); return; }
  MF.push(next);
  MS.push(next.split(' ')[0].substring(0,3).toUpperCase());
  MC.push(next.split(' ')[0].substring(0,3).toLowerCase() + next.split(' ')[1].slice(2));
  saveMF();
  renderBudgetTable('');
  updateBudgetMonthCount();
  haptic('success');
  showFB('✓ ' + next + ' ajouté', 'var(--green)');
}

function deleteLastBudgetMonth() {
  if (MF.length <= 1) { showFB('Impossible — minimum 1 mois', 'var(--red)'); return; }
  const last = MF[MF.length - 1];
  if (!confirm('Supprimer ' + last + ' ? Les dépenses de ce mois seront conservées.')) return;
  MF.pop(); MS.pop(); MC.pop();
  if (CUR >= MF.length) CUR = MF.length - 1;
  saveMF();
  renderBudgetTable('');
  updateBudgetMonthCount();
  refresh();
  haptic('success');
  showFB('✓ ' + last + ' supprimé', 'var(--amber)');
}

function saveMF() {
  localStorage.setItem('pace_mf', JSON.stringify(MF));
}

function loadMF() {
  const saved = localStorage.getItem('pace_mf');
  if (saved) {
    const arr = JSON.parse(saved);
    MF.length = 0; MS.length = 0; MC.length = 0;
    arr.forEach(m => {
      MF.push(m);
      MS.push(m.split(' ')[0].substring(0,3).toUpperCase());
      MC.push(m.split(' ')[0].substring(0,3).toLowerCase() + m.split(' ')[1].slice(2));
    });
  }
}

