// ═══════════ PIN / BIOMETRIC ═══════════
let PIN_ENTRY='';
let PIN_MODE='unlock';
let PIN_TEMP='';

function loadPinSettings(){
  const stored=localStorage.getItem('tau_pin');
  const bioOn=localStorage.getItem('tau_bio')==='1';
  const pinEl=document.getElementById('pin-toggle');
  const bioEl=document.getElementById('bio-toggle');
  const pinStatus=document.getElementById('pin-status');
  if(pinEl){pinEl.classList.toggle('on',!!stored);if(pinStatus)pinStatus.textContent=stored?'Activé':'Désactivé';}
  if(bioEl)bioEl.classList.toggle('on',bioOn);
}

function showPinScreen(mode='unlock'){
  PIN_MODE=mode; PIN_ENTRY=''; PIN_TEMP='';
  const screen=document.getElementById('pinScreen');
  const sub=document.getElementById('pin-screen-subtitle');
  const forgot=document.getElementById('pin-forgot');
  if(mode==='unlock'){if(sub)sub.textContent='Entrez votre code PIN';if(forgot)forgot.style.display='block';}
  else if(mode==='set'){if(sub)sub.textContent='Choisissez un code PIN à 4 chiffres';if(forgot)forgot.style.display='none';}
  else if(mode==='confirm'){if(sub)sub.textContent='Confirmez votre code PIN';if(forgot)forgot.style.display='none';}
  updatePinDots();
  if(screen)screen.style.display='flex';
}

function hidePinScreen(){
  const s=document.getElementById('pinScreen');
  if(s)s.style.display='none';
}

function pinKey(d){
  if(PIN_ENTRY.length>=4)return;
  PIN_ENTRY+=d;
  updatePinDots();
  if(PIN_ENTRY.length===4){
    setTimeout(()=>{
      if(PIN_MODE==='unlock'){
        const stored=localStorage.getItem('tau_pin');
        if(PIN_ENTRY===stored){hidePinScreen();}
        else{
          document.querySelectorAll('.pin-dot').forEach(el=>el.classList.add('error'));
          document.getElementById('pin-error').textContent='Code incorrect';
          setTimeout(()=>{
            PIN_ENTRY=''; updatePinDots();
            document.querySelectorAll('.pin-dot').forEach(el=>el.classList.remove('error'));
            document.getElementById('pin-error').textContent='';
          },700);
        }
      } else if(PIN_MODE==='set'){
        PIN_TEMP=PIN_ENTRY; PIN_ENTRY='';
        showPinScreen('confirm');
      } else if(PIN_MODE==='confirm'){
        if(PIN_ENTRY===PIN_TEMP){
          localStorage.setItem('tau_pin',PIN_ENTRY);
          hidePinScreen(); loadPinSettings();
          alert('Code PIN activé !');
        } else {
          document.getElementById('pin-error').textContent='Les codes ne correspondent pas';
          setTimeout(()=>{PIN_ENTRY=''; showPinScreen('set');},800);
        }
      }
    },200);
  }
}

function pinDel(){
  if(PIN_ENTRY.length>0){PIN_ENTRY=PIN_ENTRY.slice(0,-1); updatePinDots();}
}

function updatePinDots(){
  for(let i=0;i<4;i++){
    const d=document.getElementById('pd'+i);
    if(d){d.classList.toggle('filled',i<PIN_ENTRY.length); d.classList.remove('error');}
  }
}

function togglePin(){
  const stored=localStorage.getItem('tau_pin');
  if(stored){if(confirm('Désactiver le code PIN ?')){localStorage.removeItem('tau_pin'); loadPinSettings();}}
  else{showPinScreen('set');}
}

function resetPin(){
  if(confirm('Réinitialiser le code PIN ?')){
    localStorage.removeItem('tau_pin'); hidePinScreen(); loadPinSettings();
  }
}

async function tryBiometric(){
  if(!window.PublicKeyCredential){
    const stored=localStorage.getItem('tau_pin');
    if(!stored){hidePinScreen();}
    else{const el=document.getElementById('pin-error'); if(el)el.textContent='Biométrie non configurée';}
    return;
  }
  try{
    await navigator.credentials.get({publicKey:{challenge:new Uint8Array(32),rpId:location.hostname||'localhost',userVerification:'required',timeout:60000}});
    hidePinScreen();
  } catch(e){
    const el=document.getElementById('pin-error');
    if(el)el.textContent='Biométrie annulée — utilisez le PIN';
  }
}


