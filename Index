function startChallenge() {
  const type = document.getElementById('ch-type').value;
  const cat = document.getElementById('ch-cat').value;
  const days = parseInt(document.getElementById('ch-days').value) || 21;
  const amount = parseFloat(document.getElementById('ch-amount').value) || 0;
  CHALLENGE = { type, cat, days, amount, start: new Date().toISOString() };
  localStorage.setItem('tau_challenge', JSON.stringify(CHALLENGE));
  haptic('success');
  renderChallenge();
}

function finishChallenge() {
  alert('Félicitations ! Défi terminé 🏆');
  CHALLENGE = null;
  localStorage.removeItem('tau_challenge');
  renderChallenge();
}

// ═══════════ DÉTECTION ABONNEMENTS OUBLIÉS ═══════════
function detectForgottenSubs() {
  const mi = CUR;
  const warnings = [];
  const subCats = getBR().filter(r => r.cat === 'Abonnements' && (r.v[mi] || 0) > 0);
  subCats.forEach(sub => {
    const alreadySaisi = EXP.some(e => e.month === mi && (e.desc || '').toLowerCase().includes(sub.n.toLowerCase()));
    if (!alreadySaisi) {
      warnings.push({ name: sub.n, amount: sub.v[mi] });
    }
  });
  const el = document.getElementById('subs-warnings');
  if (!el) return;
  if (warnings.length === 0) {
    el.innerHTML = '<div style="font-size:.75rem;color:var(--green);padding:.5rem 0;">&#10003; Tous les abonnements sont saisis ce mois.</div>';
    return;
  }
  el.innerHTML = warnings.map(w => `
    <div class="alert-banner warn" style="margin-bottom:.4rem;">
      &#128276; <strong>${w.name}</strong> (${F(w.amount)} CHF) — pas encore saisi ce mois
      <button class="btn-edit" style="margin-left:auto;" onclick="quickAddSub('${w.name}','Abonnements',${w.amount})">+ Ajouter</button>
    </div>`).join('');
}

function quickAddSub(name, cat, amount) {
  const today = new Date().toISOString().split('T')[0];
  EXP.push({ id: Date.now(), cat, desc: name, amount, month: CUR, date: today, userId: ACTIVE_USER_ID || 'tau' });
  save(); haptic('success');
  detectForgottenSubs();
  refresh();
  showFB('&#10003; ' + name + ' ajout&eacute; !', 'var(--green)');
}

// ═══════════ ALERTE POSTE EN HAUSSE ═══════════
function detectRisingExpenses() {
  const alerts = [];
  AC.forEach(cat => {
    const vals = Array.from({ length: CUR + 1 }, (_, i) => expC(i, cat));
    if (vals.filter(v => v > 0).length < 3) return;
    const last3 = vals.slice(-3);
    if (last3[2] > last3[1] && last3[1] > last3[0] && last3[2] > 0) {
      const growth = Math.round((last3[2] - last3[0]) / last3[0] * 100);
      alerts.push({ cat, growth, current: last3[2], prev: last3[1] });
    }
  });
  return alerts;
}

// ═══════════ RÉSUMÉ IA ═══════════
async function generateAISummary() {
  const mi = CUR;
  const rev = revM(mi), sp = expT(mi), net = rev - sp;
  const bud = budM(mi);
  const topCats = AC.map(c => ({ c, v: expC(mi, c) })).filter(x => x.v > 0).sort((a, b) => b.v - a.v).slice(0, 5);
  const overCats = AC.filter(c => { const b = budC(mi, c); return b > 0 && expC(mi, c) > b; });
  const { score } = calcScore(mi);

  const prompt = `Tu es un conseiller financier bienveillant. Génère un résumé mensuel concis (5-6 phrases max) en français pour ce budget :

Mois : ${MF[mi]}
Revenu : ${F(rev)} CHF | Dépensé : ${F(sp)} CHF | Net : ${F(net)} CHF
Budget planifié : ${F(bud)} CHF | Score financier : ${score}/100
Top dépenses : ${topCats.map(x => x.c + ' ' + F(x.v) + ' CHF').join(', ')}
Catégories dépassées : ${overCats.join(', ') || 'aucune'}

Commence par une phrase d'accroche, puis analyse les points forts et points à améliorer, et termine par un conseil actionnable. Tutoie l'utilisateur.`;

  const el = document.getElementById('ai-summary-content');
