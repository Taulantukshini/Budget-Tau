// ── 5. SWIPE TO DELETE ──
function initSwipeGestures() {
  document.addEventListener('touchstart', onSwipeStart, { passive: true });
  document.addEventListener('touchmove', onSwipeMove, { passive: false });
  document.addEventListener('touchend', onSwipeEnd, { passive: true });
}

let _swipe = { el: null, startX: 0, startY: 0, dx: 0, active: false };

function onSwipeStart(e) {
  const wrap = e.target.closest('.exp-wrap');
  if (!wrap) return;
  _swipe = { el: wrap, startX: e.touches[0].clientX, startY: e.touches[0].clientY, dx: 0, active: false };
}

function onSwipeMove(e) {
  if (!_swipe.el) return;
  const dx = e.touches[0].clientX - _swipe.startX;
  const dy = e.touches[0].clientY - _swipe.startY;
  if (!_swipe.active && Math.abs(dy) > Math.abs(dx)) { _swipe.el = null; return; }
  if (!_swipe.active && Math.abs(dx) > 8) _swipe.active = true;
  if (!_swipe.active) return;
  e.preventDefault();
  _swipe.dx = dx;
  const clamped = Math.max(-90, Math.min(0, dx));
  const inner = _swipe.el.querySelector('.exp-swipe-bg') || _swipe.el;
  _swipe.el.style.transform = `translateX(${clamped}px)`;
  _swipe.el.style.transition = 'none';
  // Show red bg at -60px
  const bg = _swipe.el.querySelector('.exp-swipe-bg');
  if (bg) bg.style.opacity = Math.min(1, Math.abs(clamped) / 60);
}

function onSwipeEnd(e) {
  if (!_swipe.el || !_swipe.active) { _swipe = { el:null }; return; }
  const wrap = _swipe.el;
  const dx = _swipe.dx;
  _swipe = { el: null };

  if (dx < -60) {
    // Delete
    wrap.style.transition = 'transform 0.25s cubic-bezier(0.4,0,0.2,1), opacity 0.25s';
    wrap.style.transform = 'translateX(-100%)';
    wrap.style.opacity = '0';
    hapticEx('warning');
    const id = wrap.id?.replace('wrap-', '');
    setTimeout(() => { if (id) delExp(id); }, 250);
  } else {
    // Snap back
    wrap.style.transition = 'transform 0.4s cubic-bezier(0.34,1.56,0.64,1)';
    wrap.style.transform = 'translateX(0)';
  }
}

// ── 6. PAGE TRANSITIONS ──
let _transitioning = false;

function morphNav(pageId, tabEl) {
  if (_transitioning) return;
  if (PAGE === pageId) return;
  _transitioning = true;

  const currentPage = document.getElementById('page-' + PAGE);
  const nextPage = document.getElementById('page-' + pageId);
  if (!nextPage) { _transitioning = false; nav(pageId, tabEl); return; }

  // Determine direction
  const pages = ['dashboard','saisie','categories','score','reglages'];
  const ci = pages.indexOf(PAGE), ni = pages.indexOf(pageId);
  const dir = ni >= ci ? 1 : -1;

  if (currentPage) {
    currentPage.style.transition = 'transform 0.32s cubic-bezier(0.4,0,0.2,1), opacity 0.25s';
    currentPage.style.transform = `translateX(${dir * -40}px)`;
    currentPage.style.opacity = '0';
  }

  nextPage.style.transform = `translateX(${dir * 40}px)`;
  nextPage.style.opacity = '0';
  nextPage.style.display = 'block';

  requestAnimationFrame(() => {
    nextPage.style.transition = 'transform 0.32s cubic-bezier(0.34,1.2,0.64,1), opacity 0.25s';
    nextPage.style.transform = 'translateX(0)';
    nextPage.style.opacity = '1';
  });

  setTimeout(() => {
    nav(pageId, tabEl);
    if (currentPage) { currentPage.style.transform = ''; currentPage.style.opacity = ''; currentPage.style.transition = ''; }
    nextPage.style.transition = ''; nextPage.style.transform = ''; nextPage.style.opacity = '';
    _transitioning = false;
  }, 320);
}

