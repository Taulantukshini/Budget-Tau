  document.getElementById('list-label').textContent=MF[mi];
  document.getElementById('f-month').value=mi;
  const q=(document.getElementById('search-input')?.value||'').toLowerCase();
  let list=expM(mi).slice().reverse();
  if(q)list=EXP.filter(e=>(e.desc||'').toLowerCase().includes(q)||(e.cat||'').toLowerCase().includes(q)||(e.amount+'').includes(q)).slice().reverse();
  const tot=list.reduce((s,e)=>s+e.amount,0);
  document.getElementById('list-total').textContent=list.length>0?F(tot)+' CHF':'';
