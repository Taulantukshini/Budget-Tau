      <div><div style="font-size:.78rem;font-weight:600;">Streak actuel : ${streak.current} jour${streak.current > 1 ? 's' : ''} !</div>
      <div style="font-size:.65rem;color:var(--muted2);">Record : ${streak.best} jours &bull; Continue comme ça !</div></div></div>`;
  } else if (streakEl) { streakEl.style.display = 'none'; }
  // Rising expenses
  const rising = detectRisingExpenses();
  const risingEl = document.getElementById('rising-alerts');
  if(risingEl) risingEl.innerHTML = rising.map(r=>`<div class="alert-banner warn" style="margin-bottom:.3rem;">&#128200; <strong>${r.cat}</strong> en hausse +${r.growth}% sur 3 mois (${F(r.current)} CHF ce mois)</div>`).join('');
  // Forgotten subs
  detectForgottenSubs();
  // Hero balance card
  const heroNet=document.getElementById('hero-net');
  if(heroNet){
    heroNet.textContent=FD(Math.abs(net));
    heroNet.style.color=net>=0?'#fff':'var(--red)';
    const heroNetParent=heroNet.closest('.balance-hero');
    if(heroNetParent) heroNetParent.style.borderColor=net>=0?'rgba(123,97,255,.2)':'rgba(245,56,61,.3)';
  }
  const heroRev=document.getElementById('hero-rev-pill');if(heroRev)heroRev.textContent=F(rev)+' CHF revenu';
  const heroSp=document.getElementById('hero-spent-pill');if(heroSp)heroSp.textContent=F(sp)+' CHF dépensé';
  const heroSc=document.getElementById('hero-score-pill');if(heroSc){const sc=calcScore(mi).score;heroSc.textContent='score '+sc+'/100';}
  const dashSub=document.getElementById('dash-month-sub');if(dashSub)dashSub.textContent=MF[mi]||'';
  const recentEl=document.getElementById('dash-recent');
  if(recentEl)recentEl.innerHTML=rec.length===0?`<div class="empty"><div class="empty-ico">📭</div>Aucune dépense ce mois</div>`:`<div class="exp-list">${rec.map(expHTML).join('')}</div>`;

  // Active trip section on dashboard
  updateTripBanner();
  renderSOWidget();
  renderBalanceWidget();
  const _tripSec = document.getElementById('dash-trip-section');
  const _aTrip = getActiveTrip();
  if (_tripSec) {
    if (_aTrip) {
      _tripSec.style.display = 'block';
      const _tx = getTripExpenses(_aTrip.id);
      const _tt = _tx.reduce((s,e) => s+e.amount, 0);
      const _tr = _aTrip.budget > 0 ? _aTrip.budget - _tt : null;
      const _td = _aTrip.dateStart && _aTrip.dateEnd ? Math.ceil((new Date(_aTrip.dateEnd)-new Date(_aTrip.dateStart))/86400000)+1 : null;
      const _ta = _tx.length>0&&_td ? Math.round(_tt/_td) : null;
      const _tp = _aTrip.budget>0 ? Math.min(100,Math.round(_tt/_aTrip.budget*100)) : 0;
      const _em=document.getElementById('dash-trip-emoji'); if(_em)_em.textContent=_aTrip.emoji;
      const _nm=document.getElementById('dash-trip-name'); if(_nm)_nm.textContent=_aTrip.name;
      const _dt=document.getElementById('dash-trip-dest'); if(_dt)_dt.textContent=[_aTrip.dest,_aTrip.dateStart?(_aTrip.dateStart+(_aTrip.dateEnd?' → '+_aTrip.dateEnd:'')):null].filter(Boolean).join(' · ');
      const _kp=document.getElementById('dash-trip-kpis');
      if(_kp)_kp.innerHTML=
        `<div class="kpi-card" style="padding:10px"><div class="kpi-tag">Dépensé</div><div class="kpi-num" style="color:var(--amber);font-size:1.1rem">${F(_tt)}<span>CHF</span></div></div>`+
        (_aTrip.budget>0?`<div class="kpi-card" style="padding:10px"><div class="kpi-tag">Budget</div><div class="kpi-num" style="font-size:1.1rem">${F(_aTrip.budget)}<span>CHF</span></div></div>`:'')+
        (_tr!==null?`<div class="kpi-card" style="padding:10px"><div class="kpi-tag">Reste</div><div class="kpi-num" style="font-size:1.1rem;color:${_tr>=0?'var(--green)':'var(--red)'}">${F(_tr)}<span>CHF</span></div></div>`:'')+
        (_ta!==null?`<div class="kpi-card" style="padding:10px"><div class="kpi-tag">Moy/jour</div><div class="kpi-num" style="font-size:1.1rem;color:var(--cyan)">${F(_ta)}<span>CHF</span></div></div>`:'');
      const _b=document.getElementById('dash-trip-bar-wrap');
      if(_b)_b.innerHTML=_aTrip.budget>0
        ?`<div style="height:4px;background:var(--bg3);border-radius:2px;overflow:hidden;margin-bottom:3px"><div style="height:4px;width:${_tp}%;background:${_tp>90?'var(--red)':_tp>70?'var(--amber)':'var(--cyan)'};border-radius:2px"></div></div><div style="font-size:.62rem;color:var(--muted2);text-align:right">${_tp}% du budget · ${_tx.length} dép.</div>`
        :`<div style="font-size:.68rem;color:var(--muted2)">${_tx.length} dépense${_tx.length>1?'s':''}</div>`;
      const _xe=document.getElementById('dash-trip-exps');
      if(_xe){const _rc=_tx.slice().sort((a,b)=>(b.date||'').localeCompare(a.date||'')).slice(0,3);_xe.innerHTML=_rc.length>0?_rc.map(e=>expHTML(e)).join(''):'<div style="padding:12px 16px;font-size:.75rem;color:var(--muted2)">Aucune dépense pour ce voyage</div>';}
    } else {
      _tripSec.style.display = 'none';
    }
  }
}

