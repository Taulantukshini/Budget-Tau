// ═══════════ UNDO SUPPRESSION ═══════════
let UNDO_STACK = [];
const UNDO_MAX = 10;

function pushUndo(action) {
  UNDO_STACK.push(action);
  if (UNDO_STACK.length > UNDO_MAX) UNDO_STACK.shift();
  showUndoToast(action);
}

function showUndoToast(action) {
  let toast = document.getElementById('undo-toast');
  if (!toast) return;
  clearTimeout(window._undoTimer);
  toast.innerHTML = action.label + ' &nbsp;<button onclick="doUndo()" style="background:var(--cyan);border:none;border-radius:6px;padding:3px 10px;font-size:.72rem;font-weight:700;color:#000;cursor:pointer;font-family:\'Syne\',sans-serif;">Annuler</button>';
  toast.style.transform = 'translateY(0)';
  toast.style.opacity = '1';
  window._undoTimer = setTimeout(() => {
    toast.style.transform = 'translateY(80px)';
    toast.style.opacity = '0';
  }, 4000);
}

function doUndo() {
  const action = UNDO_STACK.pop();
  if (!action) return;
  if (action.type === 'delete_expense') {
    EXP.push(action.data);
    save(); refresh();
    haptic('success');
  }
  const toast = document.getElementById('undo-toast');
  if (toast) { toast.style.transform = 'translateY(80px)'; toast.style.opacity = '0'; }
}

// Override delExp to support undo
function delExp(id) {
  const exp = EXP.find(e => e.id === id);
  if (!exp) return;
  pushUndo({ type: 'delete_expense', data: { ...exp }, label: 'Suppression de ' + (exp.desc || exp.cat) });
  const wrap = document.getElementById('wrap-' + id);
  if (wrap) {
    wrap.style.opacity = '0';
    wrap.style.transition = 'opacity .2s';
    setTimeout(() => { EXP = EXP.filter(e => e.id !== id); save(); refresh(); }, 200);
  } else {
    EXP = EXP.filter(e => e.id !== id);
    save(); refresh();
  }
}

// ═══════════ STREAKS DE SAISIE ═══════════
function calcStreak() {
  const dates = [...new Set(EXP.map(e => e.date).filter(Boolean))].sort().reverse();
  if (!dates.length) return { current: 0, best: 0, lastDate: null };
  let current = 0, best = 0, streak = 0;
  const today = new Date().toISOString().split('T')[0];
  const yesterday = new Date(Date.now() - 86400000).toISOString().split('T')[0];
  let prev = null;
  const uniqueDates = [...new Set(dates)].sort().reverse();
  for (let i = 0; i < uniqueDates.length; i++) {
    const d = uniqueDates[i];
    if (i === 0) {
      if (d === today || d === yesterday) { streak = 1; }
      else { best = Math.max(best, streak); streak = 0; break; }
    } else {
      const diff = Math.round((new Date(prev) - new Date(d)) / 86400000);
      if (diff === 1) { streak++; }
      else { best = Math.max(best, streak); streak = 1; }
    }
    prev = d;
  }
  best = Math.max(best, streak);
  current = uniqueDates[0] === today || uniqueDates[0] === yesterday ? streak : 0;
  return { current, best, lastDate: uniqueDates[0] };
}

