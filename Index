// ═══════════ WEEK VIEW ═══════════
let WEEK_OFFSET=0;
let WEEK_SELECTED_DAY=null;

function getWeekDates(offset){
  const now=new Date();
  const day=now.getDay();
  const monday=new Date(now);
  monday.setDate(now.getDate()-(day===0?6:day-1)+(offset*7));
  monday.setHours(0,0,0,0);
  return Array.from({length:7},(_,i)=>{const d=new Date(monday);d.setDate(monday.getDate()+i);return d;});
}

function changeWeek(d){WEEK_OFFSET+=d;renderSemaine();}
function goToCurrentWeek(){WEEK_OFFSET=0;renderSemaine();}

function renderSemaine(){
  const days=getWeekDates(WEEK_OFFSET);
  const today=new Date().toISOString().split('T')[0];
  const DNAMES=['Lun','Mar','Mer','Jeu','Ven','Sam','Dim'];
  const start=days[0].toLocaleDateString('fr-CH',{day:'2-digit',month:'short'});
  const end=days[6].toLocaleDateString('fr-CH',{day:'2-digit',month:'short'});
  document.getElementById('week-badge').textContent='📅 Semaine';
  document.getElementById('week-label').textContent=start+' → '+end;

  // Total week spend
  const weekExps=EXP.filter(e=>{
    if(!e.date)return false;
    const d=e.date;
    return d>=days[0].toISOString().split('T')[0]&&d<=days[6].toISOString().split('T')[0];
  });
  const weekSpent=weekExps.reduce((s,e)=>s+e.amount,0);
  const weekBudget=Math.round(budM(CUR)/4.33);
  const wspEl=document.getElementById('week-spent');
  if(wspEl){wspEl.textContent=F(weekSpent);wspEl.className='kpi-value '+(weekSpent>weekBudget?'red':'green');}
  const wbEl=document.getElementById('week-budget');
  if(wbEl)wbEl.textContent=F(weekBudget);

  // Days grid
  const grid=document.getElementById('week-days-grid');
  if(grid){
    grid.innerHTML=days.map((d,i)=>{
      const ds=d.toISOString().split('T')[0];
      const dayExps=EXP.filter(e=>e.date===ds);
      const amt=dayExps.reduce((s,e)=>s+e.amount,0);
      const isToday=ds===today;
      const isSel=WEEK_SELECTED_DAY===ds;
      return`<div class="week-day ${isToday?'today':''} ${amt>0?'has-exp':''} ${isSel?'selected':''}" onclick="selectWeekDay('${ds}')">
        <div class="week-day-name">${DNAMES[i]}</div>
        <div class="week-day-num">${d.getDate()}</div>
        ${amt>0?`<div class="week-day-amt">${F(amt)}</div>`:''}
      </div>`;
    }).join('');
  }

  if(WEEK_SELECTED_DAY)renderWeekDayExps(WEEK_SELECTED_DAY);
  else{
    const titleEl=document.getElementById('week-day-title');
    const expsEl=document.getElementById('week-day-exps');
    if(titleEl)titleEl.textContent='Clique sur un jour';
    if(expsEl)expsEl.innerHTML='<div class="empty"><div class="empty-ico"><span class="pace-icon" style="display:inline-flex;align-items:center;justify-content:center;line-height:1;flex-shrink:0;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="17" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="16" y1="2" x2="16" y2="6"/></svg></span></div>Sélectionne un jour</div>';
  }
}

function selectWeekDay(ds){
  WEEK_SELECTED_DAY=ds;
  renderSemaine();
}
function renderWeekDayExps(ds){
  const d=new Date(ds+'T12:00:00');
  const label=d.toLocaleDateString('fr-FR',{weekday:'long',day:'numeric',month:'long'});
  const titleEl=document.getElementById('week-day-title');
  const expsEl=document.getElementById('week-day-exps');
  if(titleEl)titleEl.textContent=label.charAt(0).toUpperCase()+label.slice(1);
  const dayExps=EXP.filter(e=>e.date===ds);
  if(expsEl){
    if(dayExps.length===0)expsEl.innerHTML='<div class="empty"><div class="empty-ico">✦</div>Aucune dépense</div>';
    else expsEl.innerHTML='<div class="exp-list">'+dayExps.map(expHTML).join('')+'</div>';
  }
}

// ═══════════ HISTORIQUE COMPLET ═══════════
function renderHistorique(){
  const q=(document.getElementById('hist-search')?.value||'').toLowerCase();
  const catF=document.getElementById('hist-cat')?.value||'';
  const monthF=document.getElementById('hist-month')?.value;

  // Init filters
  const catSel=document.getElementById('hist-cat');
  if(catSel&&catSel.options.length<=1){
    AC.forEach(cat=>{const o=document.createElement('option');o.value=cat;o.textContent=cat;catSel.appendChild(o);});
    catSel.value=catF;
  }
  const monthSel=document.getElementById('hist-month');
  if(monthSel&&monthSel.options.length<=1){
    MF.forEach((m,i)=>{const o=document.createElement('option');o.value=i;o.textContent=m;monthSel.appendChild(o);});
    if(monthF)monthSel.value=monthF;
  }

  let filtered=[...EXP];
  if(q)filtered=filtered.filter(e=>(e.desc||'').toLowerCase().includes(q)||(e.cat||'').toLowerCase().includes(q)||(String(e.amount)).includes(q));
  if(catF)filtered=filtered.filter(e=>e.cat===catF);
  if(monthF!==''&&monthF!==undefined&&monthF!==null)filtered=filtered.filter(e=>String(e.month)===String(monthF));

  // Sort by date desc
  filtered.sort((a,b)=>{
    const da=a.date||'0000-00-00',db=b.date||'0000-00-00';
    return db.localeCompare(da)||b.month-a.month;
  });

  const total=filtered.reduce((s,e)=>s+e.amount,0);
  const countEl=document.getElementById('hist-count');
  const totalEl=document.getElementById('hist-total');
  if(countEl)countEl.textContent=filtered.length+' dépense'+(filtered.length>1?'s':'');
  if(totalEl)totalEl.textContent=filtered.length>0?F(total)+' CHF':'';

  const listEl=document.getElementById('hist-list');
  if(listEl){
    if(filtered.length===0)listEl.innerHTML='<div class="empty"><div class="empty-ico"><span class="pace-icon" style="display:inline-flex;align-items:center;justify-content:center;line-height:1;flex-shrink:0;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><circle cx="10.5" cy="10.5" r="6.5"/><line x1="15.5" y1="15.5" x2="21" y2="21"/></svg></span></div>Aucun résultat</div>';
    else listEl.innerHTML=filtered.map(expHTML).join('');
  }
}

