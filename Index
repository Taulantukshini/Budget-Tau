// ── SWIPE TO DELETE ──
const swipeState={};
function swipeStart(e,id){swipeState[id]={x:e.touches[0].clientX,swiped:false};}
function swipeMove(e,id){
  if(!swipeState[id])return;
  const dx=swipeState[id].x-e.touches[0].clientX;
  if(dx>10){
    const el=document.getElementById('exp-'+id);
    if(el)el.style.transform=`translateX(-${Math.min(dx,100)}px)`;
  }
}
function swipeEnd(e,id){
  if(!swipeState[id])return;
  const dx=swipeState[id].x-e.changedTouches[0].clientX;
  const el=document.getElementById('exp-'+id);
  if(dx>80){delExp(id);}
  else{if(el)el.style.transform='translateX(0)';}
  delete swipeState[id];
}

