        </div>
        <div style="display:flex;gap:4px;align-items:center;flex-shrink:0">
          ${isActive && !isCurrentActive ? `<button class="btn btn-ghost btn-sm" onclick="setActiveTrip('${trip.id}')">Activer</button>` : ''}
          ${isCurrentActive ? `<div style="font-size:.65rem;background:var(--cyan-dim);color:var(--cyan);padding:3px 8px;border-radius:10px;font-weight:700;">● Actif</div>` : ''}
          ${isActive ? `<button class="btn btn-sm" style="background:var(--green-dim);color:var(--green)" onclick="endTrip('${trip.id}')">✓ Terminer</button>` : ''}
          <button class="btn btn-sm" style="background:var(--red-dim);color:var(--red)" onclick="deleteTrip('${trip.id}')">✕</button>
        </div>
      </div>

      <div class="trip-kpis">
        <div class="trip-kpi"><div class="trip-kpi-label">Dépensé</div><div class="trip-kpi-val" style="color:var(--amber)">${F(total)} ${trip.currency}</div></div>
        ${trip.budget > 0 ? `<div class="trip-kpi"><div class="trip-kpi-label">Budget</div><div class="trip-kpi-val">${F(trip.budget)} ${trip.currency}</div></div>` : ''}
        ${remaining !== null ? `<div class="trip-kpi"><div class="trip-kpi-label">Reste</div><div class="trip-kpi-val" style="color:${remaining >= 0 ? 'var(--green)' : 'var(--red)'}">${F(remaining)}</div></div>` : ''}
        ${dailyAvg !== null ? `<div class="trip-kpi"><div class="trip-kpi-label">Moy/jour</div><div class="trip-kpi-val" style="color:var(--cyan)">${F(dailyAvg)}</div></div>` : ''}
