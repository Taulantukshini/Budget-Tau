// Barèmes suisses simplifiés 2024
const TAX_RATES_CH = {
  single: [
    { min: 0,      max: 14500,  rate: 0 },
    { min: 14500,  max: 31600,  rate: 0.077 },
    { min: 31600,  max: 41400,  rate: 0.088 },
    { min: 41400,  max: 55200,  rate: 0.099 },
    { min: 55200,  max: 72500,  rate: 0.110 },
    { min: 72500,  max: 78100,  rate: 0.121 },
    { min: 78100,  max: 103600, rate: 0.132 },
    { min: 103600, max: 134600, rate: 0.143 },
    { min: 134600, max: 176000, rate: 0.154 },
    { min: 176000, max: Infinity, rate: 0.115 },
  ]
};

function calcFederalTax(income, status) {
  const brackets = TAX_RATES_CH[status] || TAX_RATES_CH.single;
  let tax = 0;
  for (const b of brackets) {
    if (income <= b.min) break;
    const taxable = Math.min(income, b.max) - b.min;
    tax += taxable * b.rate;
  }
  return Math.round(tax);
}

function renderFiscal() {
  const el = document.getElementById('fiscal-content');
  if (!el) return;

  const data = JSON.parse(localStorage.getItem('tau_fiscal') || '{}');
  const annualRev = Array.from({length: MF.length}, (_,i) => revM(i)).reduce((a,b)=>a+b,0);
  const annualSp = Array.from({length: MF.length}, (_,i) => expT(i)).reduce((a,b)=>a+b,0);
  const annualNet = annualRev - annualSp;
  const status = data.status || 'single';
  const canton = data.canton || 'VD';
  const deductions = parseFloat(data.deductions) || 0;
  const taxableIncome = Math.max(0, annualRev - deductions);

  // Federal tax
  const fedTax = calcFederalTax(taxableIncome, status);
  // Canton multiplier (approximate rates for major cantons)
  const cantonRates = { ZH:1.15, BE:1.68, LU:1.6, UR:1.25, SZ:1.25, OW:1.25, NW:1.25, GL:1.4, ZG:0.82, FR:1.5, SO:1.45, BS:1.9, BL:1.7, SH:1.45, AR:1.3, AI:1.2, SG:1.25, GR:1.4, AG:1.25, TG:1.15, TI:1.2, VD:1.55, VS:1.5, NE:1.85, GE:1.9, JU:1.8 };
  const cantonMultiplier = cantonRates[canton] || 1.5;
  const cantonTax = Math.round(fedTax * cantonMultiplier * 0.6);
  const totalTax = fedTax + cantonTax;
  const effectiveRate = annualRev > 0 ? (totalTax / annualRev * 100).toFixed(1) : 0;
  const alreadyPaid = Array.from({length: MF.length}, (_,i) => expC(i,'Impôts')).reduce((a,b)=>a+b,0);
  const diff = totalTax - alreadyPaid;

  el.innerHTML = `
    <div class="card" style="margin-bottom:.85rem;">
      <div class="card-head"><div class="card-title">Paramètres fiscaux</div></div>
      <div class="fgroup"><label class="flabel">Situation</label>
