      tripRow.style.display = 'block';
      // Rebuild options
      tripSel.innerHTML = '<option value="">Aucun voyage</option>';
      activeTrips.forEach(t => {
        const opt = document.createElement('option');
        opt.value = t.id;
        const total = getTripExpenses(t.id).reduce((s,e) => s+e.amount, 0);
        opt.textContent = t.emoji + ' ' + t.name + (t.budget ? ' · ' + F(total) + '/' + F(t.budget) + ' CHF' : '');
        opt.selected = ACTIVE_TRIP_ID === t.id;
        tripSel.appendChild(opt);
      });
    } else {
      tripRow.style.display = 'none';
    }
  }
  // Trip indicator
  const tripInd=document.getElementById('trip-saisie-indicator');
  const activeTrip=getActiveTrip();
  if(tripInd){
    if(activeTrip){
      const tex=getTripExpenses(activeTrip.id);
      const tot=tex.reduce((s,e)=>s+e.amount,0);
      tripInd.style.display='flex';
      tripInd.innerHTML=`${activeTrip.emoji} Voyage actif : <strong>${activeTrip.name}</strong> &nbsp;·&nbsp; ${tex.length} dép. · ${F(tot)} CHF${activeTrip.budget?` · reste ${F(activeTrip.budget-tot)} CHF`:''}
        <button class="btn btn-sm" style="margin-left:auto;background:var(--red-dim);color:var(--red)" onclick="deactivateTrip();renderSaisie()">✕ Quitter</button>`;
    } else {
      tripInd.style.display='none';
    }
  }
