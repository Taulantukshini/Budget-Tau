// ═══════════ 3. SCAN TICKET IA ═══════════
async function scanReceiptAI(input, prefix) {
  if (!input.files || !input.files[0]) return;
  const file = input.files[0];
  const btn = document.getElementById(`${prefix}-scan-btn`);
  const resultEl = document.getElementById(`${prefix}-scan-result`);
  if (btn) { btn.disabled = true; btn.innerHTML = '<span>⏳</span> Analyse en cours…'; }
  if (resultEl) { resultEl.style.display = 'block'; resultEl.textContent = '🤖 Analyse du ticket par IA…'; }

  try {
    // Convert image to base64
    const base64 = await new Promise((res, rej) => {
      const reader = new FileReader();
      reader.onload = () => res(reader.result.split(',')[1]);
      reader.onerror = rej;
      reader.readAsDataURL(file);
    });
    const mimeType = file.type || 'image/jpeg';

    // Show preview
    const previewEl = document.getElementById(`${prefix}-scan-preview`);
    const previewImg = document.getElementById(`${prefix}-scan-img`);
    if (previewEl && previewImg) {
      previewImg.src = `data:${mimeType};base64,${base64}`;
      previewEl.style.display = 'block';
    }

    // Call Claude API with vision
    const prompt = `Tu analyses un ticket de caisse ou une facture. Extrais UNIQUEMENT ces informations en JSON (rien d'autre, pas de backticks) :
{
  "merchant": "nom du commerce",
  "total": 12.50,
  "date": "2026-03-15",
  "category": "Alimentation",
  "description": "courte description"
}

Catégories possibles : Alimentation, Transport, Santé/Beauté, Loisirs, Logement, Assurances, Abonnements, Voyage, Autre.
Si tu ne peux pas lire le ticket, retourne {"error": "illisible"}.
Réponds UNIQUEMENT avec le JSON, aucun texte avant ou après.`;

    const resp = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 300,
        messages: [{
          role: 'user',
          content: [
            { type: 'image', source: { type: 'base64', media_type: mimeType, data: base64 } },
            { type: 'text', text: prompt }
          ]
        }]
      })
    });

    const data = await resp.json();
    const text = data.content?.find(b => b.type === 'text')?.text || '';
    const clean = text.replace(/```json|```/g, '').trim();
    const parsed = JSON.parse(clean);

    if (parsed.error) {
      if (resultEl) { resultEl.textContent = '⚠️ Ticket illisible. Saisis les champs manuellement.'; }
    } else {
      // Fill form fields
      if (parsed.total && parsed.total > 0) {
        const amtEl = document.getElementById(`${prefix}-amount`);
        if (amtEl) amtEl.value = parsed.total;
      }
      if (parsed.category) {
        const catEl = document.getElementById(`${prefix}-cat`);
        if (catEl) catEl.value = parsed.category;
      }
      if (parsed.description || parsed.merchant) {
        const descEl = document.getElementById(`${prefix}-desc`);
        if (descEl) descEl.value = parsed.description || parsed.merchant;
      }
      if (parsed.date) {
        const dateEl = document.getElementById(`${prefix}-date`);
        if (dateEl) {
          dateEl.value = parsed.date;
          if (prefix === 'f') syncMonthFromDate('f');
        }
      }
      if (resultEl) {
        resultEl.style.background = 'var(--green-dim)';
        resultEl.style.color = 'var(--green)';
        resultEl.innerHTML = `✅ Détecté : <strong>${parsed.merchant || parsed.description}</strong> — ${parsed.total} CHF · ${parsed.category}`;
      }
      haptic('success');
      checkDuplicate();
    }
  } catch (err) {
    if (resultEl) {
      resultEl.style.background = 'var(--red-dim)';
      resultEl.style.color = 'var(--red)';
      resultEl.textContent = '⚠️ Erreur : ' + (err.message || 'connexion impossible');
    }
  } finally {
    if (btn) { btn.disabled = false; btn.innerHTML = '<span>📷</span> Scanner avec IA'; }
  }
}



