        <select class="fselect" id="ch-cat">${AC.map(c=>`<option>${c}</option>`).join('')}</select></div>
      <div class="fgroup"><label class="flabel">Dur&eacute;e (jours)</label>
        <input type="number" class="finput" id="ch-days" value="21" min="7" max="90"></div>
