function calcXP() {
  let xp = 0;
  xp += EXP.length * 5;
  xp += getEarnedBadges().length * 100;
  xp += calcStreak().best * 10;
  for (let i = 0; i <= CUR; i++) {
    if (budM(i) > 0 && expT(i) <= budM(i)) xp += 50;
    xp += Math.max(0, Math.round((revM(i) - expT(i)) / 100));
  }
  const score = calcScore(CUR).score;
  xp += score * 2;
  return Math.max(0, xp);
}

function getLevel(xp) {
  let level = LEVELS[0];
  for (const l of LEVELS) { if (xp >= l.min) level = l; }
  const idx = LEVELS.indexOf(level);
  const next = LEVELS[idx + 1];
  const progress = next ? Math.round((xp - level.min) / (next.min - level.min) * 100) : 100;
  return { ...level, xp, progress, next, idx };
}

