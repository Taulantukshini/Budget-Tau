    </div>
    <div class="kpi-bar" style="height:10px;border-radius:5px;margin-bottom:.85rem;">
      <div class="kpi-bar-fill" style="width:${pct}%;background:${isSuccess?'var(--green)':'var(--red)'};height:10px;border-radius:5px;"></div>
    </div>
    <div class="g2" style="margin-bottom:.85rem;">
      <div class="kpi-card"><div class="kpi-top"><div class="kpi-label">D&eacute;pens&eacute; (${CHALLENGE.cat})</div></div>
        <div class="kpi-value" style="color:${isSuccess?'var(--green)':'var(--red)'}">${F(catTotal)}<span>CHF</span></div></div>
      <div class="kpi-card"><div class="kpi-top"><div class="kpi-label">Objectif</div></div>
        <div class="kpi-value">${F(CHALLENGE.amount)}<span>CHF max</span></div></div>
    </div>
    <div style="display:flex;gap:.6rem;">
      <button class="btn btn-ghost" style="flex:1;justify-content:center;" onclick="if(confirm('Abandonner le d&eacute;fi ?')){CHALLENGE=null;localStorage.removeItem('tau_challenge');renderChallenge();}">Abandonner</button>
      ${remaining===0?`<button class="btn btn-cyan" style="flex:2;justify-content:center;" onclick="finishChallenge()">&#127942; Terminer</button>`:''}
    </div>`;
