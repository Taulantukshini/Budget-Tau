function checkEndOfMonthAlert() {
const now = new Date();
const daysInMonth = new Date(now.getFullYear(), now.getMonth() + 1, 0).getDate();
const daysPassed = now.getDate();
const daysLeft = daysInMonth - daysPassed;
const mi = CUR;
const sp = expT(mi), bud = budM(mi), rev = revM(mi);
if (sp === 0 || daysPassed < 5) return null;
const dailyRate = sp / daysPassed;
const projected = sp + dailyRate * daysLeft;
const projectedSavings = rev - projected;
const alerts = [];
if (projected > bud * 1.1) {
alerts.push({ type: ‘danger’, msg: `⚠️ À ce rythme, tu vas dépasser ton budget de ${F(projected - bud)} CHF d'ici la fin du mois. Rythme actuel : ${F(dailyRate)} CHF/jour.` });
} else if (projected > bud * 0.95) {
alerts.push({ type: ‘warn’, msg: `🟡 Attention : tu approches de ton budget mensuel. Il te reste ${F(bud - sp)} CHF sur ${daysLeft} jours, soit ${F((bud - sp) / Math.max(1, daysLeft))} CHF/jour.` });
}
if (projectedSavings < 0 && rev > 0) {
alerts.push({ type: ‘danger’, msg: `📉 Ton épargne projetée ce mois est négative (${F(projectedSavings)} CHF). Essaie de réduire tes dépenses variables.` });
} else if (projectedSavings > 0 && projectedSavings < rev * 0.05 && rev > 0) {
alerts.push({ type: ‘warn’, msg: `💡 Ton épargne projetée est faible ce mois (${F(projectedSavings)} CHF). Quelques jours restants pour optimiser.` });
}
return alerts;
}

