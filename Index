  if(!el)return;
  el.innerHTML=DASH_LAYOUT.map((w,i)=>`
    <div class="dash-widget" id="dw-${w.id}" draggable="true"
      ondragstart="dashDragStart(event,${i})" ondragover="dashDragOver(event,${i})" ondrop="dashDrop(event,${i})" ondragleave="dashDragLeave(event,${i})">
      <div style="display:flex;align-items:center;gap:.75rem;">
        <div class="dash-widget-handle" draggable="false">⠿</div>
        <div style="font-size:1.1rem">${w.icon}</div>
        <div style="flex:1;font-size:.82rem;font-weight:600;">${w.label}</div>
        <div class="toggle ${w.enabled?'on':''}" onclick="toggleDashWidget(${i})"></div>
      </div>
    </div>`).join('');
}

let _dragIdx=null;
function dashDragStart(e,i){_dragIdx=i;document.getElementById('dw-'+DASH_LAYOUT[i].id)?.classList.add('dragging');}
function dashDragOver(e,i){e.preventDefault();if(i!==_dragIdx)document.getElementById('dw-'+DASH_LAYOUT[i].id)?.classList.add('drag-over');}
function dashDragLeave(e,i){document.getElementById('dw-'+DASH_LAYOUT[i].id)?.classList.remove('drag-over');}
function dashDrop(e,i){
  e.preventDefault();
  if(_dragIdx===null||_dragIdx===i)return;
  document.querySelectorAll('.dash-widget').forEach(el=>el.classList.remove('dragging','drag-over'));
  const moved=DASH_LAYOUT.splice(_dragIdx,1)[0];
  DASH_LAYOUT.splice(i,0,moved);
  _dragIdx=null;
  renderDashEdit();
}
function toggleDashWidget(i){DASH_LAYOUT[i].enabled=!DASH_LAYOUT[i].enabled;renderDashEdit();}

// renderDash handles layout directly
function renderDash(){
  const mi=CUR,rev=revM(mi),bud=budM(mi),sp=expT(mi),net=rev-sp;
  const bp=rev>0?Math.min(100,bud/rev*100):0;
  const spp=rev>0?Math.min(100,sp/rev*100):0;
  document.getElementById('dash-badge').textContent='● '+MC[mi];
  document.getElementById('kpi-rev').innerHTML=F(rev)+'<span>CHF</span>';
  document.getElementById('kpi-budget').innerHTML=F(bud)+'<span>CHF</span>';
  document.getElementById('kpi-spent').innerHTML=F(sp)+'<span>CHF</span>';
  const nEl=document.getElementById('kpi-net');
  nEl.innerHTML=(net>=0?'':'-')+F(Math.abs(net))+'<span>CHF</span>';
  nEl.style.color=net>=0?'var(--green)':'var(--red)';
  document.getElementById('kb-bar').style.width=bp+'%';
  const ksBar=document.getElementById('ks-bar');ksBar.style.width=spp+'%';ksBar.style.background=spp>90?'var(--red)':'var(--amber)';
  const dEl=document.getElementById('kpi-delta');
  dEl.innerHTML=sp>0?`<span style="color:${sp<=bud?'var(--green)':'var(--red)'}">${sp<=bud?'▾':'▴'} ${Math.round(sp/Math.max(bud,1)*100)}% du budget</span>`:'<span style="color:var(--muted)">Aucune saisie</span>';

  // Apply layout visibility
  const widgetMap={
    alerts:'dash-alerts',kpis:'dash-kpis-row',projection:'dash-proj',
    compare:'dash-compare-row',progress:'dash-progress-card',recent:'dash-recent-card'
  };
  DASH_LAYOUT.forEach(w=>{
    const el=document.getElementById(widgetMap[w.id]);
    if(el)el.style.display=w.enabled?'':'none';
  });

  // Alertes
  const alerts=AC.filter(c=>{const b=budC(mi,c),s=expC(mi,c);return b>0&&(s/b)>=0.8;});
  const alertEl=document.getElementById('dash-alerts');
  if(alertEl)alertEl.innerHTML=alerts.map(cat=>{
    const b=budC(mi,cat),s=expC(mi,cat),pct=Math.round(s/b*100),over=s>b;
    return`<div class="alert-banner ${over?'':'warn'}">${over?'🔴':'🟡'} <span><strong>${cat}</strong> : ${pct}% utilisé${over?' — dépassement de '+F(s-b)+' CHF':' — '+F(b-s)+' CHF restants'}</span></div>`;
  }).join('');

  // Projection
  const monthsLeft=MF.length-mi;
  const avgSpend=mi>0?EXP.filter(e=>e.month<mi).reduce((s,e)=>s+e.amount,0)/mi:sp||budM(mi);
  const totalRevLeft=getBR().find(r=>r.cat==='Revenu').v.slice(mi).reduce((a,b)=>a+b,0);
  const projSpend=avgSpend*monthsLeft;
  const alreadySaved=Array.from({length:mi},(_,i)=>revM(i)-expT(i)).reduce((a,b)=>a+b,0);
  const projEl=document.getElementById('dash-proj');
  if(projEl)projEl.innerHTML=`<div class="proj-title">Projection fin de période</div>
    <div class="proj-row"><span class="proj-label">Revenus restants</span><span class="proj-val" style="color:var(--cyan)">${F(totalRevLeft)} CHF</span></div>
    <div class="proj-row"><span class="proj-label">Dépenses estimées</span><span class="proj-val" style="color:var(--amber)">${F(projSpend)} CHF</span></div>
    <div class="proj-row"><span class="proj-label">Épargne déjà réalisée</span><span class="proj-val" style="color:var(--green)">${F(alreadySaved)} CHF</span></div>
    <div class="proj-row" style="border-top:1px solid rgba(0,229,160,.15);padding-top:.35rem;margin-top:.2rem;"><span class="proj-label" style="font-weight:600;color:var(--text)">Total projeté</span><span class="proj-val" style="color:${alreadySaved+totalRevLeft-projSpend>=0?'var(--green)':'var(--red)'};font-size:1rem">${F(alreadySaved+totalRevLeft-projSpend)} CHF</span></div>`;

  // Compare chart
  const prevMi=mi>0?mi-1:0;
  const cats=AC.filter(c=>budC(mi,c)>0||expC(mi,c)>0||expC(prevMi,c)>0).slice(0,7);
  dc('compare');
  CHARTS['compare']=new Chart(document.getElementById('chartCompare'),{type:'bar',
    data:{labels:cats,datasets:[
      {label:MF[prevMi]?.split(' ')[0]||'Préc.',data:cats.map(c=>expC(prevMi,c)),backgroundColor:'rgba(107,114,128,.4)',borderRadius:4,borderSkipped:false},
      {label:MF[mi]?.split(' ')[0]||'Ce mois',data:cats.map(c=>expC(mi,c)),backgroundColor:cats.map(c=>cc(c)+'cc'),borderRadius:4,borderSkipped:false}
    ]},
    options:{...SO,plugins:{legend:{position:'top',labels:{boxWidth:8,font:{size:9},color:'#6b7280',padding:6}}},scales:{...gridOpts,y:{...gridOpts.y,ticks:{...gridOpts.y.ticks,callback:v=>F(v)}}}}});

  const top=AC.filter(c=>budC(mi,c)>0||expC(mi,c)>0).slice(0,6);
  const progContainer=document.getElementById('dash-progress');
  if(progContainer)progContainer.innerHTML=top.map(cat=>{
    const b=budC(mi,cat),s=expC(mi,cat),pct=b>0?Math.min(100,s/b*100):(s>0?100:0);
    const over=s>b&&b>0,warn=pct>80&&!over;
    const fc=over?'var(--red)':warn?'var(--amber)':cc(cat);
    const tag=b>0?(over?`<span class="prog-tag tag-over">+${F(s-b)}</span>`:(warn?`<span class="prog-tag tag-warn">${F(b-s)} rest.</span>`:`<span class="prog-tag tag-ok">${F(b-s)} rest.</span>`)):'';
    return`<div class="prog-item"><div class="prog-head"><div class="prog-name"><span class="prog-dot" style="background:${cc(cat)}"></span>${cat}${tag?'&nbsp;'+tag:''}</div><div class="prog-info">${F(s)}/${F(b||s)}</div></div><div class="prog-track"><div class="prog-fill" style="width:${pct}%;background:${fc};"></div></div></div>`;
  }).join('');

  const rec=expM(mi).slice(-4).reverse();
  // Streak display
  const streak = calcStreak();
  const streakEl = document.getElementById('dash-streak');
  if (streakEl && streak.current > 0) {
    streakEl.style.display = 'block';
    streakEl.innerHTML = `<div style="background:var(--amber-dim);border:1px solid rgba(255,176,32,.3);border-radius:var(--radius-sm);padding:.6rem .9rem;display:flex;align-items:center;gap:.75rem;">
