// ═══════════ IMPORT CSV BANCAIRE ═══════════
function importCSV(input) {
  if (!input.files || !input.files[0]) return;
  const reader = new FileReader();
  reader.onload = e => {
    const text = e.target.result;
    const lines = text.split('\n').map(l => l.trim()).filter(Boolean);
    if (lines.length < 2) { alert('Fichier CSV vide ou invalide'); return; }

    const header = lines[0].toLowerCase();
    const results = [];
    let imported = 0, skipped = 0, format = 'generic';

    // ── Detect Revolut format ──
    // Revolut columns: Type, Product, Started Date, Completed Date, Description, Amount, Fee, Currency, State, Balance
    const isRevolut = header.includes('completed date') || header.includes('started date') || (header.includes('description') && header.includes('currency') && header.includes('state'));

    // ── Detect PostFinance format ──
    // PostFinance: Date, Texte, Crédit CHF, Débit CHF, Solde CHF
    const isPostFinance = header.includes('crédit chf') || header.includes('debit chf') || header.includes('texte');

    // ── Detect UBS format ──
    const isUBS = header.includes('buchungstext') || header.includes('betrag');

    if (isRevolut) format = 'revolut';
    else if (isPostFinance) format = 'postfinance';
    else if (isUBS) format = 'ubs';

    console.log('CSV format detected:', format);

    // Parse header columns
    const headers = parseCSVLine(lines[0]).map(h => h.trim().toLowerCase().replace(/"/g,''));

    for (let i = 1; i < lines.length; i++) {
      const cols = parseCSVLine(lines[i]).map(v => v.trim().replace(/^"|"$/g, ''));
      if (cols.length < 2) { skipped++; continue; }

      let date = '', desc = '', amount = 0, skip = false;

      if (format === 'revolut') {
        // Revolut columns: Type, Product, Started Date, Completed Date, Description, Amount, Fee, Currency, State, Balance
        const iType     = headers.indexOf('type');
        const iComp     = headers.indexOf('completed date');
        const iStart    = headers.indexOf('started date');
        const iDesc     = headers.indexOf('description');
        const iAmt      = headers.indexOf('amount');
        const iCur      = headers.indexOf('currency');
        const iState    = headers.indexOf('state');
        const iFee      = headers.indexOf('fee');

        // Skip pending, failed, reverted transactions
        const state = iState >= 0 ? cols[iState]?.toLowerCase() : '';
        if (state === 'pending' || state === 'failed' || state === 'reverted') { skipped++; continue; }

        // Skip credits (positive amounts = incoming money), only import debits
        const rawAmt = iAmt >= 0 ? parseFloat((cols[iAmt] || '0').replace(',','.')) : 0;
        if (isNaN(rawAmt) || rawAmt >= 0) { skipped++; continue; } // skip credits & zero

        amount = Math.abs(rawAmt);

        // Date from Completed Date (format: YYYY-MM-DD HH:MM:SS or YYYY-MM-DD)
        const rawDate = (iComp >= 0 && cols[iComp]) ? cols[iComp] : (iStart >= 0 ? cols[iStart] : '');
        if (rawDate) {
          const datePart = rawDate.split(' ')[0]; // take date part only
          const parts = datePart.split('-');
          if (parts.length === 3) date = `${parts[0]}-${parts[1].padStart(2,'0')}-${parts[2].padStart(2,'0')}`;
        }

        desc = iDesc >= 0 ? cols[iDesc] : '';

        // Add fee if present
        const fee = iFee >= 0 ? parseFloat((cols[iFee] || '0').replace(',','.')) : 0;
        if (!isNaN(fee) && fee > 0) amount += fee;

      } else if (format === 'postfinance') {
        const iDate   = headers.findIndex(h => h.includes('datum') || h.includes('date'));
        const iText   = headers.findIndex(h => h.includes('texte') || h.includes('text') || h.includes('buchungstext'));
        const iDebit  = headers.findIndex(h => h.includes('débit') || h.includes('debit') || h.includes('lastschrift'));
        const iCredit = headers.findIndex(h => h.includes('crédit') || h.includes('credit') || h.includes('gutschrift'));

        const rawDate = iDate >= 0 ? cols[iDate] : '';
        if (rawDate) {
          const parts = rawDate.split('.');
          if (parts.length === 3) date = `${parts[2]}-${parts[1].padStart(2,'0')}-${parts[0].padStart(2,'0')}`;
        }
        desc = iText >= 0 ? cols[iText] : '';
        const debit  = iDebit  >= 0 ? parseFloat((cols[iDebit]  || '').replace(/\s/g,'').replace(',','.')) : 0;
        const credit = iCredit >= 0 ? parseFloat((cols[iCredit] || '').replace(/\s/g,'').replace(',','.')) : 0;
        if (!isNaN(debit)  && debit  > 0) amount = debit;
        else if (!isNaN(credit) && credit < 0) amount = Math.abs(credit);
        else { skipped++; continue; }

      } else {
        // Generic format: auto-detect columns
        for (let j = 0; j < cols.length; j++) {
          const v = cols[j];
          if (!date && /\d{2}[.\/-]\d{2}[.\/-]\d{2,4}/.test(v)) {
            const parts = v.split(/[.\/-]/);
            if (parts.length === 3) {
              const y = parts[2].length === 2 ? '20' + parts[2] : parts[2];
              date = `${y}-${parts[1].padStart(2,'0')}-${parts[0].padStart(2,'0')}`;
            }
          } else if (!date && /^\d{4}-\d{2}-\d{2}/.test(v)) {
            date = v.split(' ')[0];
          } else if (!amount && /^-?[\d\s]+[,.]?\d*$/.test(v.replace(/\s/,''))) {
            const n = parseFloat(v.replace(/\s/g,'').replace(',','.'));
            if (!isNaN(n) && Math.abs(n) > 0 && n < 0) amount = Math.abs(n);
          } else if (!desc && v.length > 2 && !/^\d/.test(v)) {
            desc = v.substring(0, 60);
          }
        }
        if (!amount) { skipped++; continue; }
      }

      if (amount > 0 && date) {
        const d = new Date(date + 'T12:00:00');
        const y = d.getFullYear(), mo = d.getMonth();
        const MNAMES = ['janvier','février','mars','avril','mai','juin','juillet','août','septembre','octobre','novembre','décembre'];
        const mi = MF.findIndex(mf => mf.toLowerCase().includes(String(y)) && mf.toLowerCase().includes(MNAMES[mo]));
        const cat = detectCategoryFromDesc(desc);
        results.push({ id: Date.now() + i, cat, desc: desc || 'Import', amount, month: mi >= 0 ? mi : CUR, date, userId: ACTIVE_USER_ID || 'tau' });
        imported++;
      } else skipped++;
    }

    if (results.length === 0) {
      alert(`Aucune transaction détectée.\nFormat : ${format}\nVérifie que le fichier contient bien des dépenses (montants négatifs pour Revolut).`);
      return;
    }

    // Deduplicate against existing expenses
    const existingKeys = new Set(EXP.map(e => `${e.date}_${e.amount}_${e.desc}`));
    const newResults = results.filter(r => !existingKeys.has(`${r.date}_${r.amount}_${r.desc}`));
    const dupes = results.length - newResults.length;

    if (!confirm(`Importer ${newResults.length} transaction${newResults.length > 1 ? 's' : ''} depuis ${format === 'revolut' ? 'Revolut' : format === 'postfinance' ? 'PostFinance' : 'CSV'} ?\n(${skipped} ignorées, ${dupes} doublons évités)`)) return;

    EXP.push(...newResults);
    save(); refresh();
    haptic('success');
    showFB(`✓ ${newResults.length} transactions importées !`, 'var(--green)');
    document.getElementById('csv-input').value = '';
  };
  reader.readAsText(input.files[0], 'UTF-8');
}


function parseCSVLine(line) {
  const result = [];
  let current = '', inQuotes = false;
  for (let i = 0; i < line.length; i++) {
    const ch = line[i];
    if (ch === '"') { inQuotes = !inQuotes; }
    else if ((ch === ',' || ch === ';') && !inQuotes) { result.push(current); current = ''; }
    else { current += ch; }
  }
  result.push(current);
  return result;
}

function detectCategoryFromDesc(desc) {
  if (!desc) return 'Autre';
  const t = desc.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
  const map = [
    ['Alimentation', ['migros','coop','lidl','aldi','denner','supermarche','restaurant','lunch','cafe','pizza','sushi']],
    ['Transport', ['sbb','cff','tpg','bus','tram','taxi','uber','essence','carburant','parking','autoroute']],
    ['Logement', ['loyer','credit','hypotheque','electricite','chauffage']],
    ['Assurances', ['assurance','insurance','css','helsana','swica']],
    ['Abonnements', ['netflix','spotify','apple','google','amazon','microsoft','adobe','gym','fitness']],
    ['Santé/Beauté', ['pharmacie','medecin','dentiste','coiffeur','apotheke']],
    ['Loisirs', ['cinema','concert','theatre','amazon','fnac','jeux']],
    ['Voyage', ['hotel','airbnb','booking','flixbus','swiss','klm','ryan']],
    ['Impôts', ['impot','tax','afc','seuil','administration']],
  ];
  for (const [cat, words] of map) { if (words.some(w => t.includes(w))) return cat; }
  return 'Autre';
}

