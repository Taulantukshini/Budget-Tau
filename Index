let CHALLENGE = JSON.parse(localStorage.getItem('tau_challenge') || 'null');

function renderChallenge() {
  const el = document.getElementById('challenge-content');
  if (!el) return;
  if (!CHALLENGE) {
    el.innerHTML = `
      <div style="text-align:center;padding:1.5rem 0;">
        <div style="font-size:2.5rem;margin-bottom:.75rem;">&#127942;</div>
