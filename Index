// ═══════════ 7. ALERTE FIN DE MOIS TENDUE ═══════════
function checkEndOfMonthAlert() {
  const now = new Date();
  const daysInMonth = new Date(now.getFullYear(), now.getMonth() + 1, 0).getDate();
  const daysPassed = now.getDate();
  const daysLeft = daysInMonth - daysPassed;
  const mi = CUR;
  const sp = expT(mi), bud = budM(mi), rev = revM(mi);
  if (sp === 0 || daysPassed < 5) return null;
  const dailyRate = sp / daysPassed;
  const projected = sp + dailyRate * daysLeft;
  const projectedSavings = rev - projected;
  const alerts = [];
  if (projected > bud * 1.1) {
    alerts.push({ type: 'danger', msg: `⚠️ À ce rythme, tu vas dépasser ton budget de ${F(projected - bud)} CHF d'ici la fin du mois. Rythme actuel : ${F(dailyRate)} CHF/jour.` });
  } else if (projected > bud * 0.95) {
    alerts.push({ type: 'warn', msg: `🟡 Attention : tu approches de ton budget mensuel. Il te reste ${F(bud - sp)} CHF sur ${daysLeft} jours, soit ${F((bud - sp) / Math.max(1, daysLeft))} CHF/jour.` });
  }
  if (projectedSavings < 0 && rev > 0) {
    alerts.push({ type: 'danger', msg: `📉 Ton épargne projetée ce mois est négative (${F(projectedSavings)} CHF). Essaie de réduire tes dépenses variables.` });
  } else if (projectedSavings > 0 && projectedSavings < rev * 0.05 && rev > 0) {
    alerts.push({ type: 'warn', msg: `💡 Ton épargne projetée est faible ce mois (${F(projectedSavings)} CHF). Quelques jours restants pour optimiser.` });
  }
  return alerts;
}



// ═══════════ SERVICE WORKER ═══════════
function registerSW() {
  if (!('serviceWorker' in navigator)) return;
  // Inline SW as blob since we can't write a separate file
  const swCode = `
const CACHE='paceapp-v17';
const ASSETS=['https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js'];
self.addEventListener('install',e=>{e.waitUntil(caches.open(CACHE).then(c=>Promise.allSettled(ASSETS.map(u=>c.add(u).catch(()=>{}))).then(()=>self.skipWaiting())));});
self.addEventListener('activate',e=>{e.waitUntil(caches.keys().then(ks=>Promise.all(ks.filter(k=>k!==CACHE).map(k=>caches.delete(k)))).then(()=>self.clients.claim()));});
self.addEventListener('fetch',e=>{
  if(e.request.url.includes('api.anthropic')||e.request.url.includes('frankfurter')||e.request.url.includes('qrserver')){
    e.respondWith(fetch(e.request).catch(()=>new Response('',{status:503})));return;
  }
  if(e.request.method!=='GET'){return;}
  e.respondWith(caches.match(e.request).then(cached=>{
    if(cached)return cached;
    return fetch(e.request).then(resp=>{
      if(!resp||resp.status!==200||resp.type==='opaque')return resp;
      const clone=resp.clone();
      caches.open(CACHE).then(c=>c.put(e.request,clone));
      return resp;
    }).catch(()=>cached||new Response('Hors ligne',{status:503}));
  }));
});`;
  const blob = new Blob([swCode], { type: 'application/javascript' });
  const swURL = URL.createObjectURL(blob);
  navigator.serviceWorker.register(swURL, { scope: '/' })
    .then(reg => {
      console.log('SW registered');
      localStorage.setItem('tau_sw', '1');
      updateOfflineStatus();
    })
    .catch(err => console.log('SW failed:', err));
}

