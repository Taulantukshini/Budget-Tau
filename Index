  document.getElementById('cat-progress').innerHTML=active.length===0
    ?`<div class="empty"><div class="empty-ico">◌</div>Commence la saisie ce mois !</div>`
    :active.map(cat=>{
      const b=budC(mi,cat),s=expC(mi,cat),pct=b>0?Math.min(100,s/b*100):(s>0?100:0);
      const over=s>b&&b>0,warn=pct>80&&!over;
      const fc=over?'var(--red)':warn?'var(--amber)':cc(cat);
      const tag=b>0?(over?`<span class="prog-tag tag-over">+${F(s-b)} dépassé</span>`:(warn?`<span class="prog-tag tag-warn">${F(b-s)} restant</span>`:`<span class="prog-tag tag-ok">${F(b-s)} restant</span>`)):'';
      return`<div class="prog-item"><div class="prog-head"><div class="prog-name"><span class="prog-dot" style="background:${cc(cat)}"></span>${cat}${tag?'&nbsp;'+tag:''}</div><div class="prog-info">${F(s)} / ${F(b||s)} CHF</div></div><div class="prog-track"><div class="prog-fill" style="width:${pct}%;background:${fc};"></div></div></div>`;
    }).join('');
  const csp=AC.filter(c=>expC(mi,c)>0);
  dc('catDonut');
  if(csp.length>0){
