const el = document.getElementById(‘fx-convert-result’);
if (!el) return;
if (!amt) { el.innerHTML = ‘’; return; }
const currencies = [{ code: ‘EUR’, symbol: ‘€’, flag: ‘🇪🇺’ }, { code: ‘USD’, symbol: ‘$’, flag: ‘🇺🇸’ }, { code: ‘GBP’, symbol: ‘£’, flag: ‘🇬🇧’ }];
el.innerHTML = currencies.map(cur => {
const rate = FX_RATES[cur.code] || 0;
if (!rate) return ‘’;
return `<div style="display:flex;justify-content:space-between;padding:.4rem .5rem;background:var(--bg2);border-radius:6px;font-size:.8rem;"> <span>${cur.flag} ${cur.code}</span> <span style="font-family:'JetBrains Mono',monospace;font-weight:700;color:var(--cyan)">${cur.symbol}${(amt * rate).toLocaleString('fr-CH', {minimumFractionDigits:2,maximumFractionDigits:2})}</span> </div>`;
