  } catch (e) {
    el.innerHTML = '<div style="color:var(--red);font-size:.75rem;">&#9888; Connexion impossible. V&eacute;rifie ta connexion internet.</div>';
  }
  if (btn) { btn.disabled = false; btn.innerHTML = '&#129302; G&eacute;n&eacute;rer un nouveau r&eacute;sum&eacute;'; }
}

// ═══════════ SIMULATEUR DE CRÉDIT ═══════════
function calcCredit() {
  const capital = parseFloat(document.getElementById('sim-capital')?.value) || 0;
  const rate = parseFloat(document.getElementById('sim-rate')?.value) || 0;
  const months = parseInt(document.getElementById('sim-months')?.value) || 12;
  if (!capital || !rate || !months) return;

  const monthlyRate = rate / 100 / 12;
  const payment = monthlyRate === 0 ? capital / months :
    capital * monthlyRate / (1 - Math.pow(1 + monthlyRate, -months));
  const totalPaid = payment * months;
  const totalInterest = totalPaid - capital;

  document.getElementById('sim-payment').textContent = FD(payment) + ' CHF/mois';
  document.getElementById('sim-total').textContent = FD(totalPaid) + ' CHF';
  document.getElementById('sim-interest').textContent = FD(totalInterest) + ' CHF';

  // Amortization chart
  const labels = [], balances = [], interests = [], principals = [];
  let balance = capital;
  for (let i = 1; i <= Math.min(months, 60); i++) {
    const int = balance * monthlyRate;
    const prin = payment - int;
    balance = Math.max(0, balance - prin);
    labels.push('M' + i);
    balances.push(Math.round(balance));
    interests.push(Math.round(int));
    principals.push(Math.round(prin));
  }

  dc('simChart');
  const simEl = document.getElementById('simChart');
  if (simEl) {
    CHARTS['simChart'] = new Chart(simEl, {
      type: 'bar',
      data: {
        labels,
        datasets: [
          { label: 'Capital restant', data: balances, backgroundColor: 'rgba(91,156,246,.6)', borderRadius: 2, borderSkipped: false },
          { label: 'Int&eacute;r&ecirc;ts', data: interests, backgroundColor: 'rgba(255,77,106,.5)', borderRadius: 2, borderSkipped: false },
        ]
      },
      options: { ...SO, plugins: { legend: { position: 'top', labels: { boxWidth: 8, font: { size: 9 }, color: '#6b7280' } } }, scales: { ...gridOpts, y: { ...gridOpts.y, ticks: { ...gridOpts.y.ticks, callback: v => F(v) } } } }
    });
  }
}

