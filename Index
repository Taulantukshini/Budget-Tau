    Math.ceil((new Date(trip.dateEnd) - new Date(trip.dateStart)) / 86400000) + 1 : null;
  const dailyAvg = exps.length > 0 && days ? Math.round(total / days) : null;

  // Group by category
  const catBreakdown = {};
  exps.forEach(e => { catBreakdown[e.cat] = (catBreakdown[e.cat] || 0) + e.amount; });
  const topCats = Object.entries(catBreakdown).sort((a, b) => b[1] - a[1]).slice(0, 4);

  return `
    <div class="trip-card ${isCurrentActive ? 'trip-card-active' : ''}" style="margin-bottom:.75rem;">
