function calcLPP() {
const salary     = parseFloat(document.getElementById(‘lpp-salary’)?.value) || 0;
const age        = parseInt(document.getElementById(‘lpp-age’)?.value) || 35;
const retireAge  = parseInt(document.getElementById(‘lpp-retire’)?.value) || 65;
const capital    = parseFloat(document.getElementById(‘lpp-capital’)?.value) || 0;
const gender     = document.getElementById(‘lpp-gender’)?.value || ‘M’;

if (!salary || !age) return;

// Déduction de coordination 2026
const coordDed = 26460;
const salaryInsured = Math.max(0, Math.min(salary, 90720) - coordDed);
const yearsLeft = Math.max(0, retireAge - age);

// Taux de cotisation selon l’âge
const getRate = (a) => {
if (a < 25) return 0;
if (a < 35) return 0.07;
if (a < 45) return 0.10;
if (a < 55) return 0.15;
return 0.18;
};

// Simulation année par année
let projectedCapital = capital;
const interestRate = 0.01; // taux minimum LPP 2026
for (let y = 0; y < yearsLeft; y++) {
const ageY = age + y;
const rate = getRate(ageY);
const annualContrib = salaryInsured * rate;
projectedCapital = (projectedCapital + annualContrib) * (1 + interestRate);
}

// Taux de conversion LPP (taux légal 6.8%)
const conversionRate = gender === ‘F’ ? 0.068 : 0.068;
const annualPension = projectedCapital * conversionRate;
const monthlyPension = annualPension / 12;

// AVS estimation simple (rente max 2026: 2520/mois)
const avsMonthly = Math.min(2520, Math.max(1260, salary / 12 * 0.1));

const totalMonthly = monthlyPension + avsMonthly;

const resEl = document.getElementById(‘lpp-results’);
if (resEl) {
resEl.style.display = ‘block’;
resEl.innerHTML = ` <div class="section-label" style="margin-top:.5rem;">Résultats simulés</div> <div class="card" style="margin-bottom:.85rem;background:linear-gradient(135deg,rgba(139,92,246,.08),rgba(0,212,255,.05));border:1px solid rgba(139,92,246,.2);"> <div style="text-align:center;padding:16px 16px 8px;"> <div style="font-size:.65rem;color:var(--muted2);text-transform:uppercase;letter-spacing:.08em;margin-bottom:4px;">Rente mensuelle totale estimée</div> <div style="font-size:2.5rem;font-weight:800;font-family:'JetBrains Mono',monospace;color:var(--cyan)">${F(Math.round(totalMonthly))} <span style="font-size:.9rem">CHF</span></div> <div style="font-size:.68rem;color:var(--muted2);margin-top:4px;">à ${retireAge} ans (dans ${yearsLeft} ans)</div> </div> </div> <div class="card" style="margin-bottom:.85rem;"> <div class="stat-row"><span class="stat-label">Salaire assuré LPP</span><span class="stat-val">${F(Math.round(salaryInsured))} CHF</span></div> <div class="stat-row"><span class="stat-label">Capital LPP projeté</span><span class="stat-val" style="color:var(--violet)">${F(Math.round(projectedCapital))} CHF</span></div> <div class="stat-row"><span class="stat-label">Rente LPP mensuelle</span><span class="stat-val" style="color:var(--violet)">${F(Math.round(monthlyPension))} CHF</span></div> <div class="stat-row"><span class="stat-label">Rente AVS estimée</span><span class="stat-val" style="color:var(--cyan)">${F(Math.round(avsMonthly))} CHF</span></div> <div class="stat-row" style="border-top:1px solid var(--border2);"><span class="stat-label" style="font-weight:700;">Total mensuel</span><span class="stat-val" style="color:var(--cyan);font-size:1rem;font-weight:800;">${F(Math.round(totalMonthly))} CHF</span></div> </div> <div class="alert alert-info" style="font-size:.72rem;line-height:1.6;">⚠️ Estimation indicative. Taux de conversion LPP: ${(conversionRate*100).toFixed(1)}%. Rendement LPP: ${(interestRate*100).toFixed(1)}%/an (taux minimum légal 2026). Consulte ton caisse de pension pour des chiffres précis.</div>`;
