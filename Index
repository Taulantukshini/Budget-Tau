        <input type="number" class="finput" id="ch-amount" value="500" min="0"></div>
      <button class="btn btn-cyan" style="width:100%;justify-content:center;" onclick="startChallenge()">&#127942; Lancer le d&eacute;fi !</button>`;
    return;
  }
  const start = new Date(CHALLENGE.start);
  const end = new Date(start); end.setDate(start.getDate() + CHALLENGE.days);
  const now = new Date();
  const elapsed = Math.max(0, Math.floor((now - start) / 86400000));
  const remaining = Math.max(0, Math.ceil((end - now) / 86400000));
  const pct = Math.min(100, Math.round(elapsed / CHALLENGE.days * 100));
  // Check if challenge conditions are met
  const startStr = CHALLENGE.start.split('T')[0];
  const endStr = end.toISOString().split('T')[0];
  const relevantExp = EXP.filter(e => e.date >= startStr && e.date <= endStr);
  const catTotal = relevantExp.filter(e => e.cat === CHALLENGE.cat).reduce((s,e) => s+e.amount, 0);
  const isSuccess = CHALLENGE.type === 'nocat' ? catTotal === 0 : catTotal <= CHALLENGE.amount;

  el.innerHTML = `
    <div style="text-align:center;margin-bottom:1rem;">
      <div style="font-size:2rem;margin-bottom:.4rem;">${isSuccess ? '&#127942;' : '&#9203;'}</div>
