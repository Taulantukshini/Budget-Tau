let TRIPS = JSON.parse(localStorage.getItem(‘pace_trips’) || ‘[]’);
let ACTIVE_TRIP_ID = localStorage.getItem(‘pace_active_trip’) || null;

function saveTrips() {
localStorage.setItem(‘pace_trips’, JSON.stringify(TRIPS));
}

function getActiveTrip() {
if (!ACTIVE_TRIP_ID) return null;
return TRIPS.find(t => t.id === ACTIVE_TRIP_ID) || null;
}

function getTrip(id) {
return TRIPS.find(t => t.id === id) || null;
}

function getTripExpenses(tripId) {
return EXP.filter(e => e.tripId === tripId);
}

// ── CREATE TRIP ──
function createTrip() {
const name = document.getElementById(‘trip-name’)?.value?.trim();
const dest = document.getElementById(‘trip-dest’)?.value?.trim();
const budget = parseFloat(document.getElementById(‘trip-budget’)?.value) || 0;
const currency = document.getElementById(‘trip-currency’)?.value || ‘CHF’;
const dateStart = document.getElementById(‘trip-start’)?.value;
const dateEnd = document.getElementById(‘trip-end’)?.value;
const emoji = document.getElementById(‘trip-emoji’)?.value || ‘✈️’;

if (!name) { showFB(‘Entre un nom pour le voyage’, ‘var(–red)’); return; }
if (!dateStart) { showFB(‘Entre une date de départ’, ‘var(–red)’); return; }

const trip = {
id: ‘trip_’ + Date.now(),
name, dest, budget, currency,
dateStart, dateEnd,
emoji,
createdAt: Date.now(),
status: ‘active’, // active | ended
};

TRIPS.push(trip);
saveTrips();
setActiveTrip(trip.id);
haptic(‘success’);
showFB(‘✈️ Voyage créé ! Mode voyage activé.’, ‘var(–cyan)’);
renderTrips();
}

// ── SET ACTIVE TRIP ──
function setActiveTrip(id) {
ACTIVE_TRIP_ID = id;
localStorage.setItem(‘pace_active_trip’, id || ‘’);
updateTripBanner();
renderSOWidget();
renderBalanceWidget();
renderTrips();
}

function deactivateTrip() {
ACTIVE_TRIP_ID = null;
localStorage.removeItem(‘pace_active_trip’);
updateTripBanner();
renderSOWidget();
renderBalanceWidget();
renderTrips();
showFB(‘Mode voyage désactivé’, ‘var(–muted2)’);
}

function endTrip(id) {
const t = getTrip(id);
if (!t) return;
t.status = ‘ended’;
t.endedAt = Date.now();
if (ACTIVE_TRIP_ID === id) {
ACTIVE_TRIP_ID = null;
localStorage.removeItem(‘pace_active_trip’);
updateTripBanner();
renderSOWidget();
renderBalanceWidget();
}
saveTrips();
renderTrips();
haptic(‘success’);
showFB(‘Voyage terminé ! Voir le résumé ci-dessous.’, ‘var(–green)’);
}

function deleteTrip(id) {
if (!confirm(‘Supprimer ce voyage ? Les dépenses liées seront conservées dans l'historique.’)) return;
TRIPS = TRIPS.filter(t => t.id !== id);
if (ACTIVE_TRIP_ID === id) {
ACTIVE_TRIP_ID = null;
localStorage.removeItem(‘pace_active_trip’);
updateTripBanner();
renderSOWidget();
renderBalanceWidget();
}
saveTrips();
renderTrips();
}

// ── TRIP BANNER (dashboard) ──
function updateTripBanner() {
const banner = document.getElementById(‘trip-banner’);
if (!banner) return;
const trip = getActiveTrip();
if (!trip) { banner.style.display = ‘none’; return; }
const exps = getTripExpenses(trip.id);
const total = exps.reduce((s, e) => s + e.amount, 0);
const pct = trip.budget > 0 ? Math.min(100, Math.round(total / trip.budget * 100)) : 0;
const remaining = trip.budget > 0 ? trip.budget - total : null;
banner.style.display = ‘block’;
banner.innerHTML = `<div class="trip-banner-inner"> <div class="trip-banner-left"> <div class="trip-banner-emoji">${trip.emoji}</div> <div> <div class="trip-banner-name">${trip.name}${trip.dest ? ' · ' + trip.dest : ''}</div> <div class="trip-banner-meta">${exps.length} dépense${exps.length > 1 ? 's' : ''} · ${F(total)} CHF${remaining !== null ? ' · reste ' + F(remaining) + ' CHF' : ''}</div> </div> </div> <div class="trip-banner-right"> <button class="btn btn-ghost btn-sm" onclick="nav('trips',null)" style="margin-right:4px">Voir →</button> <button class="btn btn-sm" style="background:var(--red-dim);color:var(--red)" onclick="deactivateTrip()">✕</button> </div> </div> ${trip.budget > 0 ?`<div class="trip-banner-bar"><div style="height:3px;width:${pct}%;background:${pct>90?'var(--red)':pct>70?'var(--amber)':'var(--cyan)'};border-radius:2px;transition:width .7s ease;"></div></div>`: ''}`;
}

