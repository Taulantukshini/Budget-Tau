// ═══════════════════════ STATE ═══════════════════════
let EXP=JSON.parse(localStorage.getItem('uks3')||'[]');
let CUR=parseInt(localStorage.getItem('uks3m')||'0');
let CHARTS={};
let PAGE='dashboard';

function save(){localStorage.setItem('uks3',JSON.stringify(EXP));localStorage.setItem('uks3m',CUR);}

// ═══════════════════════ HELPERS ═══════════════════════
const F=n=>Math.abs(n).toLocaleString('fr-CH',{maximumFractionDigits:0});
const FD=n=>n.toLocaleString('fr-CH',{minimumFractionDigits:2,maximumFractionDigits:2});
const cc=c=>CATS[c]?.c||'#4a4f5e';

function expM(mi){return EXP.filter(e=>e.month===mi);}
function expT(mi){return expM(mi).reduce((s,e)=>s+e.amount,0);}
function expC(mi,cat){return expM(mi).filter(e=>e.cat===cat).reduce((s,e)=>s+e.amount,0);}
function budM(mi){return BR.filter(r=>r.cat!=='Revenu').reduce((s,r)=>s+(r.v[mi]||0),0);}
function revM(mi){return BR.find(r=>r.n==='Salaire').v[mi]||0;}
function budC(mi,cat){return BR.filter(r=>r.cat===cat).reduce((s,r)=>s+(r.v[mi]||0),0);}
function dc(id){if(CHARTS[id]){CHARTS[id].destroy();delete CHARTS[id];}}

const SO={responsive:true,maintainAspectRatio:false};
const gridOpts={x:{grid:{color:'rgba(255,255,255,.03)'},ticks:{color:'#4a4f5e'}},y:{grid:{color:'rgba(255,255,255,.03)'},ticks:{color:'#4a4f5e'}}};

// ═══════════════════════ INIT ═══════════════════════
function initAll(){
  // Month selects
  const mo=MF.map((m,i)=>`<option value="${i}">${m}</option>`).join('');
  ['desktopMonth','mobileMonth','f-month','m-month'].forEach(id=>{
    const el=document.getElementById(id);if(el){el.innerHTML=mo;el.value=CUR;}
  });
  // Cat selects
  const co=AC.map(c=>`<option value="${c}">${c}</option>`).join('');
  ['f-cat','m-cat'].forEach(id=>{const el=document.getElementById(id);if(el)el.innerHTML=co;});
}

// ═══════════════════════ MONTH ═══════════════════════
function setMonth(v){
  CUR=parseInt(v);
  ['desktopMonth','mobileMonth','f-month','m-month'].forEach(id=>{
    const el=document.getElementById(id);if(el)el.value=CUR;
  });
  save();refresh();
}

// ═══════════════════════ NAV ═══════════════════════
const PAGE_LABELS={dashboard:'Dashboard',saisie:'Saisie dépenses',categories:'Par catégorie',annuel:'Vue annuelle',budget:'Budget planifié'};

function nav(page,el){
  PAGE=page;
  // desktop sidebar
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  if(el&&el.classList.contains('nav-item')) el.classList.add('active');
  else document.querySelectorAll('.nav-item').forEach(n=>{if(n.getAttribute('onclick')?.includes(`'${page}'`))n.classList.add('active');});
  // mobile tabs
  document.querySelectorAll('.tab-item').forEach(t=>t.classList.remove('active'));
  const tabEl=document.getElementById('tab-'+page);if(tabEl)tabEl.classList.add('active');
  // pages
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.getElementById('page-'+page).classList.add('active');
  // topbar
  const tbt=document.getElementById('tb-title');if(tbt)tbt.textContent=PAGE_LABELS[page];
  refresh();
}

function refresh(){
  updateSidebar();
  if(PAGE==='dashboard') renderDash();
  else if(PAGE==='saisie') renderSaisie();
  else if(PAGE==='categories') renderCat();
  else if(PAGE==='annuel') renderAnnuel();
  else if(PAGE==='budget') renderBudgetTable();
}

// ═══════════════════════ SIDEBAR KPIs ═══════════════════════
function updateSidebar(){
  const mi=CUR,rev=revM(mi),sp=expT(mi),net=rev-sp;
  document.getElementById('sb-rev').textContent=F(rev);
  document.getElementById('sb-spent').textContent=F(sp);
  const el=document.getElementById('sb-net');
  el.textContent=(net>=0?'+':'-')+F(Math.abs(net));
  el.style.color=net>=0?'var(--green)':'var(--red)';
}

// ═══════════════════════ EXPENSE ITEM HTML ═══════════════════════
function expHTML(e){
  const c=cc(e.cat);
  return`<div class="exp-item">
    <span class="exp-dot" style="background:${c}"></span>
    <div>
      <div class="exp-name">${e.desc||e.cat}</div>
      <div class="exp-meta">${MF[e.month]} · <span class="exp-cat-badge" style="background:${c}20;color:${c}">${e.cat}</span></div>
    </div>
    <span class="exp-amount">${FD(e.amount)}</span>
    <button class="btn-danger" onclick="delExp(${e.id})">✕</button>
  </div>`;
}

// ═══════════════════════ ADD ═══════════════════════
function submitExpense(){
  const cat=document.getElementById('f-cat').value;
  const desc=document.getElementById('f-desc').value.trim();
  const amount=parseFloat(document.getElementById('f-amount').value);
  const month=parseInt(document.getElementById('f-month').value);
  if(isNaN(amount)||amount<=0){showFB('Montant invalide !','var(--red)');return;}
  EXP.push({id:Date.now(),cat,desc,amount,month});save();
  document.getElementById('f-amount').value='';
  document.getElementById('f-desc').value='';
  showFB(`✓ ${FD(amount)} CHF ajouté`,'var(--green)');
  refresh();
}

function submitModal(){
  const cat=document.getElementById('m-cat').value;
  const desc=document.getElementById('m-desc').value.trim();
  const amount=parseFloat(document.getElementById('m-amount').value);
  const month=parseInt(document.getElementById('m-month').value);
  if(isNaN(amount)||amount<=0){alert('Montant invalide');return;}
  EXP.push({id:Date.now(),cat,desc,amount,month});save();
  document.getElementById('m-amount').value='';
  document.getElementById('m-desc').value='';
  closeModal();refresh();
}

function delExp(id){EXP=EXP.filter(e=>e.id!==id);save();refresh();}
function showFB(m,c){const el=document.getElementById('f-feedback');if(!el)return;el.textContent=m;el.style.color=c;setTimeout(()=>el.textContent='',2500);}

// ═══════════════════════ DASHBOARD ═══════════════════════
function renderDash(){
  const mi=CUR,rev=revM(mi),bud=budM(mi),sp=expT(mi),net=rev-sp;
  const bp=rev>0?Math.min(100,bud/rev*100):0;
  const spp=rev>0?Math.min(100,sp/rev*100):0;
  document.getElementById('dash-badge').textContent='● '+MC[mi];
  document.getElementById('kpi-rev').innerHTML=F(rev)+'<span>CHF</span>';
  document.getElementById('kpi-budget').innerHTML=F(bud)+'<span>CHF</span>';
  document.getElementById('kpi-spent').innerHTML=F(sp)+'<span>CHF</span>';
  const nEl=document.getElementById('kpi-net');
  nEl.innerHTML=(net>=0?'':'-')+F(Math.abs(net))+'<span>CHF</span>';
  nEl.style.color=net>=0?'var(--green)':'var(--red)';
  document.getElementById('kb-bar').style.width=bp+'%';
  const ksBar=document.getElementById('ks-bar');ksBar.style.width=spp+'%';ksBar.style.background=spp>90?'var(--red)':'var(--amber)';
  const dEl=document.getElementById('kpi-delta');
  dEl.innerHTML=sp>0?`<span style="color:${sp<=bud?'var(--green)':'var(--red)'}">${sp<=bud?'▾':'▴'} ${(sp/Math.max(bud,1)*100).toFixed(0)}% du budget</span>`:'<span style="color:var(--muted)">Aucune saisie</span>';

  // Donut
  const csp=AC.filter(c=>expC(mi,c)>0);
  dc('dashDonut');
  if(csp.length>0){
    CHARTS['dashDonut']=new Chart(document.getElementById('chartDashDonut'),{type:'doughnut',
      data:{labels:csp,datasets:[{data:csp.map(c=>expC(mi,c)),backgroundColor:csp.map(c=>cc(c)),borderWidth:0,hoverOffset:5}]},
      options:{...SO,cutout:'68%',plugins:{legend:{position:'right',labels:{boxWidth:8,font:{size:10},color:'#6b7280',padding:6}}}}});
  }

  // Progress
  const top=AC.filter(c=>budC(mi,c)>0||expC(mi,c)>0).slice(0,5);
  document.getElementById('dash-progress').innerHTML=top.map(cat=>{
    const b=budC(mi,cat),s=expC(mi,cat),pct=b>0?Math.min(100,s/b*100):(s>0?100:0);
    const over=s>b&&b>0,warn=pct>80&&!over;
    const fc=over?'var(--red)':warn?'var(--amber)':cc(cat);
    const tag=b>0?(over?`<span class="prog-tag tag-over">+${F(s-b)}</span>`:(warn?`<span class="prog-tag tag-warn">${F(b-s)} rest.</span>`:`<span class="prog-tag tag-ok">${F(b-s)} rest.</span>`)):'';
    return`<div class="prog-item"><div class="prog-head"><div class="prog-name"><span class="prog-dot" style="background:${cc(cat)}"></span>${cat}${tag?'&nbsp;'+tag:''}</div><div class="prog-info">${F(s)}/${F(b||s)}</div></div><div class="prog-track"><div class="prog-fill" style="width:${pct}%;background:${fc};"></div></div></div>`;
  }).join('');

  // Recent
  const rec=expM(mi).slice(-4).reverse();
  document.getElementById('dash-recent').innerHTML=rec.length===0
    ?`<div class="empty"><div class="empty-ico">📭</div>Aucune dépense ce mois</div>`
    :`<div class="exp-list">${rec.map(expHTML).join('')}</div>`;
}

// ═══════════════════════ SAISIE ═══════════════════════
function renderSaisie(){
  const mi=CUR;
  document.getElementById('saisie-badge').textContent='● '+MC[mi];
  document.getElementById('list-label').textContent=MF[mi];
  document.getElementById('f-month').value=mi;
  const list=expM(mi).slice().reverse();
  const tot=list.reduce((s,e)=>s+e.amount,0);
  document.getElementById('list-total').textContent=list.length>0?F(tot)+' CHF':'';
  const el=document.getElementById('exp-list');
  el.innerHTML=list.length===0?`<div class="empty"><div class="empty-ico">✦</div>Aucune dépense — ${MF[mi]}</div>`:list.map(expHTML).join('');
}

// ═══════════════════════ CATEGORIES ═══════════════════════
function renderCat(){
  const mi=CUR;
  document.getElementById('cat-badge').textContent='● '+MC[mi];
  const active=AC.filter(c=>budC(mi,c)>0||expC(mi,c)>0);
  document.getElementById('cat-progress').innerHTML=active.length===0
    ?`<div class="empty"><div class="empty-ico">◌</div>Commence la saisie ce mois !</div>`
    :active.map(cat=>{
      const b=budC(mi,cat),s=expC(mi,cat),pct=b>0?Math.min(100,s/b*100):(s>0?100:0);
      const over=s>b&&b>0,warn=pct>80&&!over;
      const fc=over?'var(--red)':warn?'var(--amber)':cc(cat);
      const tag=b>0?(over?`<span class="prog-tag tag-over">+${F(s-b)} dépassé</span>`:(warn?`<span class="prog-tag tag-warn">${F(b-s)} restant</span>`:`<span class="prog-tag tag-ok">${F(b-s)} restant</span>`)):'';
      return`<div class="prog-item"><div class="prog-head"><div class="prog-name"><span class="prog-dot" style="background:${cc(cat)}"></span>${cat}${tag?'&nbsp;'+tag:''}</div><div class="prog-info">${F(s)} / ${F(b||s)} CHF</div></div><div class="prog-track"><div class="prog-fill" style="width:${pct}%;background:${fc};"></div></div></div>`;
    }).join('');

  const csp=AC.filter(c=>expC(mi,c)>0);
  dc('catDonut');
  if(csp.length>0){
    CHARTS['catDonut']=new Chart(document.getElementById('chartCatDonut'),{type:'doughnut',
      data:{labels:csp,datasets:[{data:csp.map(c=>expC(mi,c)),backgroundColor:csp.map(c=>cc(c)),borderWidth:0,hoverOffset:5}]},
      options:{...SO,cutout:'66%',plugins:{legend:{display:false}}}});
    const tot=csp.reduce((s,c)=>s+expC(mi,c),0);
    document.getElementById('cat-legend').innerHTML=csp.map(c=>{
      const v=expC(mi,c),pct=tot>0?(v/tot*100).toFixed(0):0;
      return`<div style="display:flex;justify-content:space-between;align-items:center;font-size:.7rem;"><div style="display:flex;align-items:center;gap:.35rem;"><span style="width:6px;height:6px;border-radius:2px;background:${cc(c)};display:inline-block;"></span><span style="color:var(--muted2)">${c}</span></div><span style="font-family:'JetBrains Mono',monospace;color:var(--text)">${F(v)} <span style="color:var(--muted)">${pct}%</span></span></div>`;
    }).join('');
  }

  const hasAny=AC.filter(c=>EXP.some(e=>e.cat===c));
  dc('catEvol');
  CHARTS['catEvol']=new Chart(document.getElementById('chartCatEvol'),{type:'line',
    data:{labels:MS,datasets:hasAny.map(cat=>({label:cat,data:Array.from({length:12},(_,i)=>expC(i,cat)),borderColor:cc(cat),backgroundColor:cc(cat)+'22',tension:.4,pointRadius:3,fill:false,pointBackgroundColor:cc(cat)}))},
    options:{...SO,plugins:{legend:{position:'bottom',labels:{boxWidth:8,font:{size:9},color:'#6b7280',padding:6}}},scales:{...gridOpts,y:{...gridOpts.y,ticks:{...gridOpts.y.ticks,callback:v=>F(v)}}}}});
}

// ═══════════════════════ ANNUEL ═══════════════════════
function renderAnnuel(){
  const revRow=BR.find(r=>r.n==='Salaire');
  const revs=revRow.v;
  const dep=BR.filter(r=>r.cat!=='Revenu');
  const deps=Array.from({length:12},(_,i)=>dep.reduce((s,r)=>s+(r.v[i]||0),0));
  const nets=revs.map((r,i)=>r-deps[i]);
  const cumul=[];let c=0;nets.forEach(n=>{c+=n;cumul.push(c);});
  const co={...SO,plugins:{legend:{labels:{boxWidth:8,font:{size:10},color:'#6b7280'}}},scales:{...gridOpts,y:{...gridOpts.y,ticks:{...gridOpts.y.ticks,callback:v=>F(v)}}}};

  dc('annBar');CHARTS['annBar']=new Chart(document.getElementById('chartAnnBar'),{type:'bar',
    data:{labels:MS,datasets:[{label:'Revenu',data:revs,backgroundColor:'rgba(0,212,255,.5)',borderRadius:4,borderSkipped:false},{label:'Dépenses',data:deps,backgroundColor:'rgba(255,77,106,.5)',borderRadius:4,borderSkipped:false}]},options:co});
  dc('annCumul');CHARTS['annCumul']=new Chart(document.getElementById('chartAnnCumul'),{type:'line',
    data:{labels:MS,datasets:[{label:'Épargne',data:cumul,borderColor:'var(--green)',backgroundColor:'rgba(0,229,160,.08)',fill:true,tension:.4,pointRadius:3,pointBackgroundColor:'var(--green)'}]},
    options:{...SO,plugins:{legend:{display:false}},scales:{...gridOpts,y:{...gridOpts.y,ticks:{...gridOpts.y.ticks,callback:v=>F(v)}}}}});
  dc('annNet');CHARTS['annNet']=new Chart(document.getElementById('chartAnnNet'),{type:'bar',
    data:{labels:MS,datasets:[{label:'Net',data:nets,backgroundColor:nets.map(n=>n>=0?'rgba(0,229,160,.55)':'rgba(255,77,106,.55)'),borderRadius:4,borderSkipped:false}]},
    options:{...SO,plugins:{legend:{display:false}},scales:{...gridOpts,y:{...gridOpts.y,ticks:{...gridOpts.y.ticks,callback:v=>F(v)}}}}});
}

// ═══════════════════════ BUDGET TABLE ═══════════════════════
function renderBudgetTable(f=''){
  const t=document.getElementById('budgetTable');
  const rows=BR.filter(r=>r.cat!=='Revenu'&&r.n.toLowerCase().includes(f.toLowerCase()));
  t.querySelector('thead').innerHTML=`<tr><th>Cat.</th><th>Poste</th>${MS.map(m=>`<th class="r">${m}</th>`).join('')}<th class="r">Total</th></tr>`;
  t.querySelector('tbody').innerHTML=rows.map(r=>{
    const tot=r.v.reduce((a,b)=>a+b,0);const c=cc(r.cat);
    return`<tr><td><span style="font-size:.62rem;font-weight:600;padding:.1rem .4rem;border-radius:4px;background:${c}1a;color:${c}">${r.cat}</span></td><td class="nc">${r.n}</td>${r.v.map(v=>`<td class="r" style="color:${v>0?'var(--muted2)':'rgba(74,79,94,.35)'}">${v>0?F(v):'-'}</td>`).join('')}<td class="r hl">${tot>0?F(tot):'-'}</td></tr>`;
  }).join('');
  const dep=BR.filter(r=>r.cat!=='Revenu');
  const tots=Array.from({length:12},(_,i)=>dep.reduce((s,r)=>s+(r.v[i]||0),0));
  const rv=BR.find(r=>r.n==='Salaire').v;
  const nts=rv.map((r,i)=>r-tots[i]);
  const cu=[];let cc2=0;nts.forEach(n=>{cc2+=n;cu.push(cc2);});
  t.querySelector('tfoot').innerHTML=`
    <tr><td></td><td class="nc">Dépenses</td>${tots.map(v=>`<td class="r">${F(v)}</td>`).join('')}<td class="r">${F(tots.reduce((a,b)=>a+b))}</td></tr>
    <tr><td></td><td class="nc">Net</td>${nts.map(n=>`<td class="r ${n>=0?'pos':'neg'}">${n>=0?'+':'-'}${F(Math.abs(n))}</td>`).join('')}<td></td></tr>
    <tr style="background:rgba(0,212,255,.04)"><td></td><td class="nc" style="color:var(--cyan)">Cumulé</td>${cu.map(n=>`<td class="r hl">${F(n)}</td>`).join('')}<td></td></tr>`;
}

// ═══════════════════════ MODAL ═══════════════════════
function openModal(){document.getElementById('quickModal').classList.add('open');document.getElementById('m-month').value=CUR;}
function closeModal(){document.getElementById('quickModal').classList.remove('open');}
document.getElementById('quickModal').addEventListener('click',e=>{if(e.target===e.currentTarget)closeModal();});
// Swipe down to close modal
let _ty=0;
document.querySelector('.modal').addEventListener('touchstart',e=>{_ty=e.touches[0].clientY;},{passive:true});
document.querySelector('.modal').addEventListener('touchmove',e=>{if(e.touches[0].clientY-_ty>60)closeModal();},{passive:true});

// ═══════════════════════ BOOT ═══════════════════════
initAll();
refresh();
</script>

