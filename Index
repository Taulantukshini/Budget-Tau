// ── RECURRENTS ──
function renderRecurrents(){
  const mi=CUR;
  document.getElementById('recur-badge').textContent='● '+MC[mi];
  document.getElementById('recur-month-label').textContent=MF[mi];
  const already=new Set(expM(mi).map(e=>e.desc));
  const grid=document.getElementById('recur-grid');
  grid.innerHTML=RECURRENTS.map(r=>{
    const row=BR.find(b=>b.n===r.budgetRow);
    const amt=row?row.v[mi]:0;
    if(amt===0)return'';
    const done=already.has(r.n);
    const sel=SELECTED_RECUR.has(r.n);
    return`<div class="recur-card ${sel?'selected':''} ${done?'':''}${done?' style="opacity:.45;pointer-events:none;"':''}" onclick="toggleRecur('${r.n}')" id="rc-${r.n.replace(/\s/g,'_')}">
      <span class="prog-dot" style="background:${cc(r.cat)}"></span>
      <div style="flex:1;min-width:0"><div class="recur-name">${r.n}</div><div class="recur-amt">${F(amt)} CHF${done?' · ✓ déjà ajouté':''}</div></div>
      <div class="recur-check">${sel?'✓':''}</div>
    </div>`;
  }).join('');
}

function toggleRecur(name){
  if(SELECTED_RECUR.has(name))SELECTED_RECUR.delete(name);
  else SELECTED_RECUR.add(name);
  renderRecurrents();
}

function selectAllRecur(){
  const mi=CUR;
  const already=new Set(expM(mi).map(e=>e.desc));
  RECURRENTS.forEach(r=>{
    const row=BR.find(b=>b.n===r.budgetRow);
    const amt=row?row.v[mi]:0;
    if(amt>0&&!already.has(r.n))SELECTED_RECUR.add(r.n);
  });
  renderRecurrents();
}

function addRecurrents(){
  const mi=CUR;
  const today=new Date().toISOString().split('T')[0];
  let added=0;
  SELECTED_RECUR.forEach(name=>{
    const r=RECURRENTS.find(x=>x.n===name);if(!r)return;
    const row=BR.find(b=>b.n===r.budgetRow);
    const amt=row?row.v[mi]:0;
    if(amt>0){EXP.push({id:Date.now()+added,cat:r.cat,desc:r.n,amount:amt,month:mi,date:today});added++;}
  });
  if(added>0){save();SELECTED_RECUR.clear();
    const fb=document.getElementById('recur-feedback');
    fb.textContent=`✓ ${added} charge${added>1?'s':''} ajoutée${added>1?'s':''}`;
    fb.style.color='var(--green)';
    setTimeout(()=>{fb.textContent='';},3000);
    refresh();
  }
}

