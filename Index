const HapticPatterns = {
  light:    [5],
  medium:   [10],
  heavy:    [20],
  success:  [5, 50, 10],
  warning:  [10, 30, 10, 30, 10],
  error:    [20, 60, 20],
  selection:[3],
  impact:   [15],
};

function hapticEx(type = 'light') {
  if (!navigator.vibrate) return;
  const pattern = HapticPatterns[type] || HapticPatterns.light;
  navigator.vibrate(pattern);
}

// Override the existing haptic
window.haptic = function(type) {
  const map = { success: 'success', light: 'light', medium: 'medium', error: 'error' };
  hapticEx(map[type] || 'light');
};

// ── 3. DYNAMIC ISLAND NOTIFICATIONS ──
let _diQueue = [];
let _diShowing = false;

function showDynamicIsland(opts = {}) {
  // opts: { icon, title, subtitle, color, duration, onTap }
  _diQueue.push(opts);
  if (!_diShowing) _processDIQueue();
}

function _processDIQueue() {
  if (_diQueue.length === 0) { _diShowing = false; return; }
  _diShowing = true;
  const opts = _diQueue.shift();
  const di = document.getElementById('dynamic-island');
  if (!di) { _diShowing = false; return; }

  const color = opts.color || 'var(--cyan)';
  di.innerHTML = `
    <div class="di-inner" style="--di-color:${color}">
      ${opts.icon ? `<div class="di-icon">${opts.icon}</div>` : ''}
      <div class="di-text">
        ${opts.title ? `<div class="di-title">${opts.title}</div>` : ''}
        ${opts.subtitle ? `<div class="di-sub">${opts.subtitle}</div>` : ''}
      </div>
    </div>`;

  di.classList.remove('di-hide');
  di.classList.add('di-show');
  hapticEx('light');

  if (opts.onTap) {
    di.onclick = () => { opts.onTap(); dismissDI(); };
  } else {
    di.onclick = dismissDI;
  }

  const dur = opts.duration || 3000;
  setTimeout(dismissDI, dur);
}

function dismissDI() {
  const di = document.getElementById('dynamic-island');
  if (!di) return;
  di.classList.remove('di-show');
  di.classList.add('di-hide');
  setTimeout(() => {
    di.classList.remove('di-hide');
    di.innerHTML = '';
    setTimeout(_processDIQueue, 200);
  }, 400);
}

