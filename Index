// ═══════════ PARTAGE RÉCAPITULATIF EN IMAGE ═══════════
function shareRecap() {
  const mi = CUR;
  const rev = revM(mi), sp = expT(mi), net = rev - sp;
  const bud = budM(mi);
  const canvas = document.createElement('canvas');
  canvas.width = 800; canvas.height = 500;
  const ctx = canvas.getContext('2d');

  // Background
  const isDark = !document.body.classList.contains('light');
  ctx.fillStyle = isDark ? '#0f1923' : '#f5f6fa';
  ctx.fillRect(0, 0, 800, 500);

  // Header band
  const grad = ctx.createLinearGradient(0, 0, 800, 0);
  grad.addColorStop(0, '#00d4ff22');
  grad.addColorStop(1, '#8b5cf622');
  ctx.fillStyle = grad;
  ctx.fillRect(0, 0, 800, 80);

  // Title
  ctx.fillStyle = '#00d4ff';
  ctx.font = 'bold 28px monospace';
  ctx.fillText('PACE', 40, 50);
  ctx.fillStyle = isDark ? '#6b7280' : '#8890a4';
  ctx.font = '16px monospace';
  ctx.fillText(MF[mi] || '', 260, 50);

  // KPI boxes
  const kpis = [
    { label: 'Revenu', value: F(rev) + ' CHF', color: '#00d4ff' },
    { label: 'Dépensé', value: F(sp) + ' CHF', color: '#ffb020' },
    { label: 'Budget', value: F(bud) + ' CHF', color: '#8b5cf6' },
    { label: net >= 0 ? 'Épargne' : 'Déficit', value: F(Math.abs(net)) + ' CHF', color: net >= 0 ? '#00e5a0' : '#ff4d6a' },
  ];
  kpis.forEach((k, i) => {
    const x = 40 + i * 185, y = 110;
    ctx.fillStyle = isDark ? '#111318' : '#ffffff';
    roundRect(ctx, x, y, 170, 80, 10);
    ctx.fillStyle = k.color + '22';
    roundRect(ctx, x, y, 170, 80, 10);
    ctx.fillStyle = isDark ? '#4a4f5e' : '#8890a4';
    ctx.font = '11px monospace';
    ctx.fillText(k.label.toUpperCase(), x + 12, y + 22);
    ctx.fillStyle = k.color;
    ctx.font = 'bold 20px monospace';
    ctx.fillText(k.value, x + 12, y + 55);
  });

  // Category bars
  const cats = AC.filter(c => budC(mi, c) > 0 || expC(mi, c) > 0).slice(0, 6);
  ctx.fillStyle = isDark ? '#f0f1f5' : '#1a1d2e';
  ctx.font = 'bold 13px monospace';
  ctx.fillText('DÉPENSES PAR CATÉGORIE', 40, 230);
  cats.forEach((cat, i) => {
    const y = 250 + i * 35;
    const b = budC(mi, cat), s = expC(mi, cat);
    const pct = b > 0 ? Math.min(1, s / b) : (s > 0 ? 1 : 0);
    const barW = 500;
    ctx.fillStyle = isDark ? '#181b21' : '#e8eaf0';
    roundRect(ctx, 40, y, barW, 18, 5);
    ctx.fillStyle = pct > 0.9 ? '#ff4d6a' : pct > 0.7 ? '#ffb020' : cc(cat);
    roundRect(ctx, 40, y, Math.max(6, barW * pct), 18, 5);
    ctx.fillStyle = isDark ? '#f0f1f5' : '#1a1d2e';
    ctx.font = '12px monospace';
    ctx.fillText(cat, 560, y + 13);
    ctx.fillStyle = isDark ? '#6b7280' : '#8890a4';
    ctx.font = '11px monospace';
    ctx.fillText(F(s) + '/' + F(b), 680, y + 13);
  });

  // Footer
  ctx.fillStyle = isDark ? '#4a4f5e' : '#8890a4';
  ctx.font = '11px monospace';
  ctx.fillText('PACE · ' + new Date().toLocaleDateString('fr-CH'), 40, 480);

  // Download / share
  canvas.toBlob(blob => {
    const url = URL.createObjectURL(blob);
    if (navigator.share && navigator.canShare({ files: [new File([blob], 'budget.png', { type: 'image/png' })] })) {
      navigator.share({ title: 'PACE — ' + MF[mi], files: [new File([blob], 'budget.png', { type: 'image/png' })] });
    } else {
      const a = document.createElement('a');
      a.href = url; a.download = 'BudgetTAU_' + (MF[mi] || '').replace(' ', '_') + '.png';
      a.click();
    }
    URL.revokeObjectURL(url);
  });
}

function roundRect(ctx, x, y, w, h, r) {
  ctx.beginPath();
  ctx.moveTo(x + r, y);
  ctx.lineTo(x + w - r, y);
  ctx.quadraticCurveTo(x + w, y, x + w, y + r);
  ctx.lineTo(x + w, y + h - r);
  ctx.quadraticCurveTo(x + w, y + h, x + w - r, y + h);
  ctx.lineTo(x + r, y + h);
  ctx.quadraticCurveTo(x, y + h, x, y + h - r);
  ctx.lineTo(x, y + r);
  ctx.quadraticCurveTo(x, y, x + r, y);
  ctx.closePath();
  ctx.fill();
}

