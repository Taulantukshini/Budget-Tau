      ${topCats.length > 0 ? `
        <div style="padding:0 14px 10px;display:flex;flex-wrap:wrap;gap:5px;">
          ${topCats.map(([cat, val]) => `<div style="font-size:.68rem;padding:3px 8px;border-radius:10px;background:${cc(cat)}20;color:${cc(cat)};font-weight:600">${cat} ${F(val)}</div>`).join('')}
