// ═══════════════════════════════════════
// ORDRES PERMANENTS
// Dépenses automatiques chaque mois
// ═══════════════════════════════════════

let STANDING_ORDERS = JSON.parse(localStorage.getItem('tau_standing_orders') || '[]');

function saveStandingOrders() {
  localStorage.setItem('tau_standing_orders', JSON.stringify(STANDING_ORDERS));
}

// ── CREATE / EDIT ──
function saveStandingOrder() {
  const id      = document.getElementById('so-id')?.value || null;
  const name    = document.getElementById('so-name')?.value?.trim();
  const cat     = document.getElementById('so-cat')?.value;
  const amount  = parseFloat(document.getElementById('so-amount')?.value);
  const day     = parseInt(document.getElementById('so-day')?.value) || 1;
  const active  = document.getElementById('so-active')?.classList.contains('on');
  const note    = document.getElementById('so-note')?.value?.trim() || '';

  if (!name)   { showFB('Entre un nom', 'var(--red)'); return; }
  if (!amount || amount <= 0) { showFB('Entre un montant valide', 'var(--red)'); return; }

  if (id) {
    // Edit existing
    const idx = STANDING_ORDERS.findIndex(o => o.id === id);
    if (idx >= 0) {
      STANDING_ORDERS[idx] = { ...STANDING_ORDERS[idx], name, cat, amount, day, active, note };
    }
  } else {
    // New
    STANDING_ORDERS.push({
      id:        'so_' + Date.now(),
      name, cat, amount, day,
      active:    true,
      note,
      createdAt: Date.now(),
      lastRun:   null,  // YYYY-MM format of last auto-add
    });
  }

  saveStandingOrders();
  resetSOForm();
  haptic('success');
  showFB('✅ Ordre permanent enregistré !', 'var(--green)');
  renderStandingOrders();
}

function editStandingOrder(id) {
  const o = STANDING_ORDERS.find(o => o.id === id);
  if (!o) return;
  document.getElementById('so-id').value      = o.id;
  document.getElementById('so-name').value    = o.name;
  document.getElementById('so-cat').value     = o.cat;
  document.getElementById('so-amount').value  = o.amount;
  document.getElementById('so-day').value     = o.day;
  document.getElementById('so-note').value    = o.note || '';
  const toggle = document.getElementById('so-active');
  if (toggle) toggle.classList.toggle('on', o.active);
  const btn = document.getElementById('so-submit-btn');
  if (btn) btn.textContent = '💾 Modifier';
  document.getElementById('so-form-title').textContent = 'Modifier l\'ordre';
  document.getElementById('so-cancel-btn').style.display = 'block';
  // Scroll to form
  document.getElementById('so-form-card')?.scrollIntoView({ behavior: 'smooth' });
}

function deleteStandingOrder(id) {
  if (!confirm('Supprimer cet ordre permanent ?')) return;
  STANDING_ORDERS = STANDING_ORDERS.filter(o => o.id !== id);
  saveStandingOrders();
  renderStandingOrders();
  haptic('light');
}

function toggleSOActive(id) {
  const o = STANDING_ORDERS.find(o => o.id === id);
  if (!o) return;
  o.active = !o.active;
  saveStandingOrders();
  renderStandingOrders();
  haptic('light');
}

function resetSOForm() {
  document.getElementById('so-id').value     = '';
  document.getElementById('so-name').value   = '';
  document.getElementById('so-amount').value = '';
  document.getElementById('so-day').value    = '1';
  document.getElementById('so-note').value   = '';
  const toggle = document.getElementById('so-active');
  if (toggle) toggle.classList.add('on');
  const btn = document.getElementById('so-submit-btn');
  if (btn) btn.textContent = '＋ Créer l\'ordre';
  if (document.getElementById('so-form-title')) document.getElementById('so-form-title').textContent = 'Nouvel ordre permanent';
  if (document.getElementById('so-cancel-btn')) document.getElementById('so-cancel-btn').style.display = 'none';
}

// ── AUTO-RUN: check and execute due orders ──
function runStandingOrders(force = false) {
  if (STANDING_ORDERS.length === 0) return;
  const now  = new Date();
  const ym   = `${now.getFullYear()}-${String(now.getMonth()+1).padStart(2,'0')}`;
  const today = now.getDate();
  let added = 0;
  const details = [];

  STANDING_ORDERS.forEach(o => {
    if (!o.active) return;
    // Already run this month?
    if (o.lastRun === ym && !force) return;
    // Not yet the scheduled day? (unless forced)
    if (today < o.day && !force) return;

    // Find the matching budget month
    const MNAMES = ['janvier','février','mars','avril','mai','juin','juillet','août','septembre','octobre','novembre','décembre'];
    const mi = MF.findIndex(mf =>
      mf.toLowerCase().includes(String(now.getFullYear())) &&
      mf.toLowerCase().includes(MNAMES[now.getMonth()])
    );
    const targetMonth = mi >= 0 ? mi : CUR;

    // Check if already added this month (avoid duplicates)
    const alreadyExists = EXP.some(e =>
      e.standingOrderId === o.id &&
      e.month === targetMonth
    );
    if (alreadyExists) {
      o.lastRun = ym;
      return;
    }

    // Build the date string for this month
    const daysInMonth = new Date(now.getFullYear(), now.getMonth()+1, 0).getDate();
    const safeDay = Math.min(o.day, daysInMonth);
    const dateStr = `${now.getFullYear()}-${String(now.getMonth()+1).padStart(2,'0')}-${String(safeDay).padStart(2,'0')}`;

    EXP.push({
      id:              Date.now() + Math.random(),
      cat:             o.cat,
      desc:            o.name + (o.note ? ' — ' + o.note : ''),
      amount:          o.amount,
      month:           targetMonth,
      date:            dateStr,
      userId:          ACTIVE_USER_ID || 'tau',
      standingOrderId: o.id,
      auto:            true,
    });

    o.lastRun = ym;
    added++;
    details.push(`${o.name} (${F(o.amount)} CHF)`);
  });

  if (added > 0) {
    saveStandingOrders();
    save();
    refresh();
    haptic('success');
    // Show notification
    showSONotification(added, details);
  }
}

function showSONotification(count, details) {
  // In-app toast
  const msg = count === 1
    ? `↺ Ordre permanent ajouté : ${details[0]}`
    : `↺ ${count} ordres permanents ajoutés automatiquement`;
  showFB(msg, 'var(--cyan)');

  // Push notification if enabled
  if ('Notification' in window && Notification.permission === 'granted') {
    new Notification('PACE — Ordres permanents', {
      body: details.join(', ') + ' ont été ajoutés automatiquement.',
      tag: 'standing-orders'
    });
  }
}

function runSOManually(id) {
  const o = STANDING_ORDERS.find(o => o.id === id);
  if (!o) return;
  const now = new Date();
  const ym = `${now.getFullYear()}-${String(now.getMonth()+1).padStart(2,'0')}`;
  const alreadyExists = EXP.some(e => e.standingOrderId === o.id && e.month === CUR);
  if (alreadyExists) {
    if (!confirm('Cet ordre a déjà été exécuté ce mois. Ajouter quand même ?')) return;
  }
  const MNAMES = ['janvier','février','mars','avril','mai','juin','juillet','août','septembre','octobre','novembre','décembre'];
  const daysInMonth = new Date(now.getFullYear(), now.getMonth()+1, 0).getDate();
  const safeDay = Math.min(o.day, daysInMonth);
  const dateStr = `${now.getFullYear()}-${String(now.getMonth()+1).padStart(2,'0')}-${String(safeDay).padStart(2,'0')}`;
  EXP.push({
    id: Date.now(),
    cat: o.cat,
