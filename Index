function generateQR() {
  const el = document.getElementById('qr-display');
  if (!el) return;
  const data = JSON.stringify({ v: 1, exp: EXP.slice(-100), ts: Date.now() });
  const encoded = btoa(unescape(encodeURIComponent(data)));
  const url = 'https://pace-sync.vercel.app/import#' + encoded.substring(0, 500);
  // Use QR API
  const qrUrl = `https://api.qrserver.com/v1/create-qr-code/?size=200x200&data=${encodeURIComponent(encoded.substring(0,300))}`;
  el.innerHTML = `
    <div style="text-align:center;padding:1rem 0;">
      <img src="${qrUrl}" style="border-radius:12px;width:180px;height:180px;background:#fff;padding:8px;" onerror="this.style.display='none';document.getElementById('qr-fallback').style.display='block'">
      <div id="qr-fallback" style="display:none;background:var(--bg3);border-radius:12px;padding:1rem;margin-bottom:.75rem;">
        <div style="font-size:.72rem;color:var(--muted2);word-break:break-all;font-family:'JetBrains Mono',monospace;">${encoded.substring(0,100)}...</div>
      </div>
      <div style="font-size:.72rem;color:var(--muted2);margin-top:.75rem;line-height:1.5;">Scanne ce QR code depuis un autre appareil pour importer tes 100 derni\u00e8res d\u00e9penses.</div>
      <button class="btn btn-ghost btn-sm" style="margin-top:.75rem;" onclick="copyQRData()">&#128203; Copier les donn\u00e9es</button>
    </div>`;
  window._qrData = encoded;
}

function copyQRData() {
  if (!window._qrData) return;
  navigator.clipboard.writeText(window._qrData).then(() => {
    showFB('Donn\u00e9es copi\u00e9es !', 'var(--green)');
  }).catch(() => {
    const ta = document.createElement('textarea');
    ta.value = window._qrData;
    document.body.appendChild(ta); ta.select();
    document.execCommand('copy');
    document.body.removeChild(ta);
    showFB('Donn\u00e9es copi\u00e9es !', 'var(--green)');
  });
}

function importFromQR() {
  const val = document.getElementById('qr-import-input')?.value?.trim();
  if (!val) { alert('Colle les donn\u00e9es QR ici'); return; }
  try {
    const decoded = JSON.parse(decodeURIComponent(escape(atob(val))));
    if (!decoded.exp || !Array.isArray(decoded.exp)) throw new Error('Format invalide');
    if (!confirm(`Importer ${decoded.exp.length} d\u00e9penses depuis QR ?`)) return;
    const newIds = new Set(EXP.map(e => e.id));
    const toAdd = decoded.exp.filter(e => !newIds.has(e.id));
    EXP.push(...toAdd);
    save(); refresh();
    haptic('success');
    alert(`\u2713 ${toAdd.length} d\u00e9penses import\u00e9es (${decoded.exp.length - toAdd.length} doublons ignor\u00e9s)`);
  } catch (e) {
    alert('Donn\u00e9es invalides : ' + e.message);
  }
}

