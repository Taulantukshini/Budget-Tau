function saveSOFromForm() {
  const name   = document.getElementById('f-desc')?.value?.trim() || document.getElementById('f-cat')?.value;
  const cat    = document.getElementById('f-cat')?.value;
  const amount = parseFloat(document.getElementById('f-amount')?.value);
  const day    = parseInt(document.getElementById('f-so-day')?.value) || 1;
  const note   = document.getElementById('f-so-note')?.value?.trim() || '';

  if (!amount || amount <= 0) { showFB("Entre un montant d'abord", 'var(--red)'); return; }

  // Check if already exists
  const exists = STANDING_ORDERS.find(o =>
    o.name === name && o.cat === cat && Math.abs(o.amount - amount) < 0.01
  );
  if (exists) {
    showFB('Cet ordre existe déjà !', 'var(--amber)');
    return;
  }

  STANDING_ORDERS.push({
    id:        'so_' + Date.now(),
    name:      name || cat,
    cat, amount, day,
    active:    true,
    note,
    createdAt: Date.now(),
    lastRun:   null,
  });

  saveStandingOrders();
  haptic('success');

  // Close panel
  const panel = document.getElementById('f-so-quick-panel');
  const btn   = document.getElementById('f-so-toggle-btn');
