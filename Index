// ═══════════ 2. PACEX DE CHANGE EN TEMPS RÉEL ═══════════
let FX_RATES = { EUR: 0.93, USD: 1.09, GBP: 0.79 };
let FX_LOADED = false;
let FX_LAST_FETCH = 0;

async function fetchFXRates() {
const now = Date.now();
if (FX_LOADED && now - FX_LAST_FETCH < 3600000) return; // cache 1h
try {
const r = await fetch(‘https://api.frankfurter.app/latest?from=CHF&to=EUR,USD,GBP’);
if (!r.ok) throw new Error(’HTTP ’ + r.status);
const data = await r.json();
if (data.rates) {
FX_RATES = data.rates;
FX_LOADED = true;
FX_LAST_FETCH = now;
localStorage.setItem(‘pace_fx’, JSON.stringify({ rates: FX_RATES, ts: now }));
}
} catch (e) {
const cached = localStorage.getItem(‘pace_fx’);
if (cached) { const d = JSON.parse(cached); FX_RATES = d.rates; FX_LOADED = true; }
}
renderFX();
}

function renderFX() {
const el = document.getElementById(‘fx-content’);
if (!el) return;
const mi = CUR;
const rev = revM(mi), sp = expT(mi), net = rev - sp;
const currencies = [
{ code: ‘EUR’, symbol: ‘€’, flag: ‘🇪🇺’ },
{ code: ‘USD’, symbol: ‘$’, flag: ‘🇺🇸’ },
{ code: ‘GBP’, symbol: ‘£’, flag: ‘🇬🇧’ },
];
const ts = FX_LAST_FETCH ? new Date(FX_LAST_FETCH).toLocaleTimeString(‘fr-CH’, { hour: ‘2-digit’, minute: ‘2-digit’ }) : ‘cache’;
el.innerHTML = `<div style="font-size:.62rem;color:var(--muted2);margin-bottom:.75rem;font-family:'JetBrains Mono',monospace;">Mis à jour : ${ts} · 1 CHF = …</div> ${currencies.map(cur => { const rate = FX_RATES[cur.code] || 0; if (!rate) return ''; return`<div class="fx-row">
<div class="fx-flag">${cur.flag}</div>
<div class="fx-info">
<div class="fx-name">${cur.code}</div>
<div class="fx-rate">1 CHF = ${rate.toFixed(4)} ${cur.code}</div>
</div>
<div class="fx-amounts">
<div class="fx-amt" style="color:var(--cyan)">Net : ${cur.symbol}${Math.round(net * rate).toLocaleString(‘fr-CH’)}</div>
<div class="fx-amt-sub">Rev : ${cur.symbol}${Math.round(rev * rate).toLocaleString(‘fr-CH’)} · Dep : ${cur.symbol}${Math.round(sp * rate).toLocaleString(‘fr-CH’)}</div>
</div>
