function fillFromFav(i) {
  const fav = FAVORITES[i];
  if (!fav) return;
  document.getElementById('f-cat').value = fav.cat;
  document.getElementById('f-amount').value = fav.amount;
  document.getElementById('f-desc').value = fav.desc || '';
  haptic('light');
  showFB('&#11088; Favori charg&eacute; !', 'var(--amber)');
}

function addCurrentToFav() {
  const cat = document.getElementById('f-cat')?.value;
  const amt = parseFloat(document.getElementById('f-amount')?.value);
  const desc = document.getElementById('f-desc')?.value?.trim();
  if (!amt || amt <= 0) { showFB('Saisis un montant d\'abord', 'var(--red)'); return; }
  if (FAVORITES.length >= 8) { showFB('Maximum 8 favoris', 'var(--amber)'); return; }
  FAVORITES.push({ cat, amount: amt, desc });
  saveFavorites();
  renderFavorites();
  haptic('success');
  showFB('&#11088; Ajout&eacute; aux favoris !', 'var(--amber)');
}

function removeFav(i) {
  FAVORITES.splice(i, 1);
  saveFavorites();
  renderFavorites();
  haptic('light');
}

// ═══════════ 6. SAISIE VOCALE ═══════════
let voiceRecognition = null;
function startVoice() {
  const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
  if (!SpeechRecognition) { showFB('Reconnaissance vocale non disponible', 'var(--red)'); return; }
  if (voiceRecognition) { voiceRecognition.stop(); return; }
  voiceRecognition = new SpeechRecognition();
  voiceRecognition.lang = 'fr-CH';
  voiceRecognition.interimResults = false;
  voiceRecognition.maxAlternatives = 1;
  const btn = document.getElementById('voice-btn');
  const res = document.getElementById('voice-result');
  btn.classList.add('listening');
  btn.innerHTML = '<span style="font-size:1.1rem">&#128308;</span> En &eacute;coute... (re-appuyer pour arr&ecirc;ter)';
  haptic('medium');
  voiceRecognition.onresult = (e) => {
    const transcript = e.results[0][0].transcript.toLowerCase();
    res.style.display = 'block';
    res.textContent = '"' + transcript + '"';
    parseVoiceInput(transcript);
    haptic('success');
  };
  voiceRecognition.onerror = () => {
    btn.classList.remove('listening');
    btn.innerHTML = '<span style="font-size:1.1rem">&#127908;</span> Saisie vocale';
    voiceRecognition = null;
    showFB('Erreur micro — r&eacute;essaie', 'var(--red)');
  };
  voiceRecognition.onend = () => {
    btn.classList.remove('listening');
    btn.innerHTML = '<span style="font-size:1.1rem">&#127908;</span> Saisie vocale';
    voiceRecognition = null;
  };
  voiceRecognition.start();
}

function parseVoiceInput(text) {
  const amtMatch = text.match(/(\d+[\.,]?\d*)\s*(franc|chf|fr|euros?|eur)?/i);
  if (amtMatch) document.getElementById('f-amount').value = parseFloat(amtMatch[1].replace(',', '.'));
  const catColors = getCatColors();
  const catMap = {
    'migros': 'Alimentation', 'coop': 'Alimentation', 'restaurant': 'Alimentation', 'lunch': 'Alimentation', 'repas': 'Alimentation', 'manger': 'Alimentation',
    'essence': 'Transport', 'train': 'Transport', 'bus': 'Transport', 'taxi': 'Transport', 'transport': 'Transport',
    'loyer': 'Logement', 'credit': 'Logement', 'appartement': 'Logement',
    'pharmacie': 'Santé/Beauté', 'coiffeur': 'Santé/Beauté', 'medecin': 'Santé/Beauté',
    'abonnement': 'Abonnements', 'netflix': 'Abonnements', 'sport': 'Abonnements', 'gym': 'Abonnements',
    'voyage': 'Voyage', 'hotel': 'Voyage', 'vacances': 'Voyage',
    'loisir': 'Loisirs', 'cinema': 'Loisirs', 'sortie': 'Loisirs',
  };
  for (const [kw, cat] of Object.entries(catMap)) {
    if (text.includes(kw)) { document.getElementById('f-cat').value = cat; break; }
  }
  const words = text.replace(/\d+[\.,]?\d*/g, '').replace(/franc|chf|fr|euro|eur/gi, '').trim();
  if (words.length > 2) document.getElementById('f-desc').value = words.charAt(0).toUpperCase() + words.slice(1);
  showFB('&#127908; Champs remplis !', 'var(--violet)');
}

// ═══════════ 7. VERROUILLAGE AUTOMATIQUE ═══════════
let AUTO_LOCK_TIMER = null;
