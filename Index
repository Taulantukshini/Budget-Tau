      <div class="fgroup"><label class="flabel">Canton</label>
        <select class="fselect" id="fis-canton" onchange="saveFiscalParams()">
          ${Object.keys(cantonRates).map(c=>`<option value="${c}" ${canton===c?'selected':''}>${c}</option>`).join('')}
        </select></div>
      <div class="fgroup"><label class="flabel">Déductions estimées (CHF)</label>
        <input type="number" id="fis-deductions" class="finput" value="${deductions}" placeholder="Ex: 3000 (frais prof., 3e pilier…)" oninput="saveFiscalParams()"></div>
    </div>
    <div class="g2" style="margin-bottom:.85rem;">
      <div class="kpi-card"><div class="kpi-tag">Revenu imposable</div><div class="kpi-num" style="color:var(--cyan)">${F(taxableIncome)}<span>CHF</span></div></div>
      <div class="kpi-card"><div class="kpi-tag">Taux effectif</div><div class="kpi-num" style="color:var(--amber)">${effectiveRate}<span>%</span></div></div>
    </div>
    <div class="card" style="margin-bottom:.85rem;">
      <div class="card-head" style="margin-bottom:4px;"><div class="card-title">Estimation impôts</div></div>
      <div class="stat-row"><span class="stat-label">Impôt fédéral direct</span><span class="stat-val" style="color:var(--amber)">${F(fedTax)} CHF</span></div>
      <div class="stat-row"><span class="stat-label">Impôt cantonal + communal (${canton})</span><span class="stat-val" style="color:var(--amber)">${F(cantonTax)} CHF</span></div>
      <div class="stat-row" style="border-top:1px solid var(--border2)"><span class="stat-label" style="font-weight:700">Total estimé</span><span class="stat-val" style="color:var(--red);font-size:1rem;font-weight:800">${F(totalTax)} CHF</span></div>
    </div>
    <div class="card" style="margin-bottom:.85rem;">
      <div class="card-head" style="margin-bottom:4px;"><div class="card-title">Acomptes vs Estimation</div></div>
      <div class="stat-row"><span class="stat-label">Acomptes déjà saisis</span><span class="stat-val" style="color:var(--cyan)">${F(alreadyPaid)} CHF</span></div>
      <div class="stat-row"><span class="stat-label">Estimation totale</span><span class="stat-val">${F(totalTax)} CHF</span></div>
      <div class="stat-row" style="border-top:1px solid var(--border2)">
        <span class="stat-label" style="font-weight:700">${diff > 0 ? 'Complément à payer' : 'Surplus versé'}</span>
        <span class="stat-val" style="color:${diff>0?'var(--red)':'var(--green)'};font-weight:800">${diff>0?'+':''}${F(diff)} CHF</span>
