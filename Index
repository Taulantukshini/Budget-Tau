function scheduleSmartNotifications() {
  if (localStorage.getItem('tau_smart_notif') !== '1') return;
  clearInterval(window._smartNotifTimer);
  window._smartNotifTimer = setInterval(() => {
    checkAndNotify();
  }, 3600000); // Check every hour
  checkAndNotify(); // Check immediately
}

function checkAndNotify() {
  if (!('Notification' in window) || Notification.permission !== 'granted') return;
  if (localStorage.getItem('tau_smart_notif') !== '1') return;
  const mi = CUR;
  const sp = expT(mi), bud = budM(mi), rev = revM(mi);
  const now = new Date();
  const daysInMonth = new Date(now.getFullYear(), now.getMonth() + 1, 0).getDate();
  const daysPassed = now.getDate();
  const daysLeft = daysInMonth - daysPassed;
  const dailyRate = daysPassed > 0 ? sp / daysPassed : 0;
  const projected = sp + dailyRate * daysLeft;
  const lastNotif = parseInt(localStorage.getItem('tau_last_notif') || '0');
  const cooldown = 6 * 3600000; // 6h between notifications

  if (Date.now() - lastNotif < cooldown) return;

  let title = '', body = '', urgent = false;

  // Budget dépassé
  if (bud > 0 && sp > bud) {
    title = '⚠️ Budget dépassé !';
    body = `Tu as dépassé ton budget de ${F(sp - bud)} CHF ce mois. (${F(sp)} / ${F(bud)} CHF)`;
    urgent = true;
  }
  // Budget va être dépassé
  else if (bud > 0 && projected > bud * 1.05 && daysLeft > 0) {
    title = '🟡 Budget bientôt dépassé';
    body = `À ce rythme, tu dépasseras ton budget de ${F(Math.round(projected - bud))} CHF fin de mois.`;
  }
  // Pas de saisie depuis 3 jours
  else {
    const lastEntry = EXP.filter(e => e.date).map(e => e.date).sort().reverse()[0];
    if (lastEntry) {
      const daysSince = Math.floor((Date.now() - new Date(lastEntry + 'T12:00:00')) / 86400000);
      if (daysSince >= 3) {
        title = '📝 N\'oublie pas de saisir';
        body = `Aucune dépense depuis ${daysSince} jours. Tes données sont-elles à jour ?`;
      }
    }
  }

  if (title) {
    localStorage.setItem('tau_last_notif', Date.now().toString());
    new Notification(title, { body, tag: 'paceapp-alert', icon: '' });
    if (urgent) haptic('error');
  }
}

