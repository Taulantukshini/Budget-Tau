// ── DATE <-> MONTH SYNC ──
function syncMonthFromDate(prefix){
  const dateEl=document.getElementById(prefix+'-date');
  const monthEl=document.getElementById(prefix+'-month');
  if(!dateEl||!monthEl||!dateEl.value)return;
  const d=new Date(dateEl.value+'T12:00:00');
  const y=d.getFullYear(), m=d.getMonth();
  // Find matching month index in MF
  const MNAMES_FR=['janvier','février','mars','avril','mai','juin','juillet','août','septembre','octobre','novembre','décembre'];
  const mi=MF.findIndex(mf=>mf.toLowerCase().includes(String(y))&&mf.toLowerCase().includes(MNAMES_FR[m]));
  if(mi>=0){
    monthEl.value=mi;
    // Visual feedback
    monthEl.style.borderColor='var(--cyan)';
    setTimeout(()=>monthEl.style.borderColor='',1200);
  } else {
    // Date outside budget range - warn user
    monthEl.style.borderColor='var(--amber)';
    setTimeout(()=>monthEl.style.borderColor='',2000);
  }
}

function syncDateFromMonth(prefix){
  const dateEl=document.getElementById(prefix+'-date');
  const monthEl=document.getElementById(prefix+'-month');
  if(!dateEl||!monthEl)return;
  const mi=parseInt(monthEl.value);
  const mfLabel=MF[mi]; // e.g. "Mars 2026"
  if(!mfLabel)return;
  // Extract year from label
  const yearMatch=mfLabel.match(/\d{4}/);
  if(!yearMatch)return;
  const yr=yearMatch[0];
  // Get current day from existing date, or use 1
  const existingDay=dateEl.value?new Date(dateEl.value+'T12:00:00').getDate():1;
  // Build new date: keep day, change month/year
  const MNAMES_FR=['janvier','février','mars','avril','mai','juin','juillet','août','septembre','octobre','novembre','décembre'];
  const mIdx=MNAMES_FR.findIndex(mn=>mfLabel.toLowerCase().includes(mn));
  if(mIdx<0)return;
  const paddedMonth=String(mIdx+1).padStart(2,'0');
  const daysInMonth=new Date(parseInt(yr),mIdx+1,0).getDate();
  const safeDay=Math.min(existingDay,daysInMonth);
  const paddedDay=String(safeDay).padStart(2,'0');
  const newDate=`${yr}-${paddedMonth}-${paddedDay}`;
  dateEl.value=newDate;
  // Visual feedback
  dateEl.style.borderColor='var(--cyan)';
  setTimeout(()=>dateEl.style.borderColor='',1200);
}


