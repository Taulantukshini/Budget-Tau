async function requestNotifPermission(){
  if(!('Notification' in window)){alert('Les notifications ne sont pas supportées sur ce navigateur.');return;}
  const perm=await Notification.requestPermission();
  if(perm==='granted'){
    localStorage.setItem('tau_notif','1');
    scheduleMonthlyReminder();
    new Notification('PACE',{body:'Notifications activées ! Tu seras rappelé le 1er de chaque mois.',icon:'data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><text y=".9em" font-size="90">💰</text></svg>'});
  }
}
function scheduleMonthlyReminder(){
  // Check daily if it's the 1st of the month
  const checkNotif=()=>{
    const now=new Date();
    if(now.getDate()===1&&now.getHours()===9&&localStorage.getItem('tau_notif')==='1'){
      new Notification('PACE — Nouveau mois !',{body:'N\'oublie pas d\'enregistrer tes dépenses récurrentes pour '+MONTHS_FR_FULL[now.getMonth()]+'.'});
    }
  };
  setInterval(checkNotif,3600000); // Check every hour
}


