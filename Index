// ═══════════ 2. VIBRATION HAPTIQUE ═══════════
function haptic(type = 'light') {
  if (!navigator.vibrate) return;
  const patterns = { light: [10], medium: [20], success: [10, 50, 10], error: [50, 30, 50] };
  navigator.vibrate(patterns[type] || [10]);
}

// ═══════════ 3. PRÉDICTION FIN DE MOIS ═══════════
function renderPrediction() {
  const mi = CUR;
  const now = new Date();
  const daysInMonth = new Date(now.getFullYear(), now.getMonth() + 1, 0).getDate();
  const daysPassed = now.getDate();
  const daysLeft = daysInMonth - daysPassed;
  const sp = expT(mi);
  const bud = budM(mi);
  const rev = revM(mi);
  if (sp === 0 || daysPassed === 0) { document.getElementById('dash-predict').style.display = 'none'; return; }
  const dailyRate = sp / daysPassed;
  const projectedTotal = sp + (dailyRate * daysLeft);
  const projectedSavings = rev - projectedTotal;
  const over = projectedTotal > bud;
  const el = document.getElementById('dash-predict');
  if (!el) return;
  el.style.display = 'block';
  el.innerHTML = `<div class="predict-title">&#128302; Pr&eacute;diction fin de mois</div>
    <div class="predict-row"><span class="predict-label">D&eacute;penses actuelles</span><span class="predict-val" style="color:var(--amber)">${F(sp)} CHF</span></div>
    <div class="predict-row"><span class="predict-label">Rythme journalier</span><span class="predict-val">${F(dailyRate)} CHF/j</span></div>
    <div class="predict-row"><span class="predict-label">Total pr&eacute;vu fin de mois</span><span class="predict-val" style="color:${over ? 'var(--red)' : 'var(--green)'}">${F(projectedTotal)} CHF</span></div>
    <div class="predict-row" style="border-top:1px solid rgba(255,176,32,.15);padding-top:.3rem;margin-top:.15rem;">
      <span class="predict-label" style="font-weight:600;color:var(--text)">&Eacute;pargne pr&eacute;vue</span>
      <span class="predict-val" style="color:${projectedSavings >= 0 ? 'var(--green)' : 'var(--red)'}; font-size:.9rem">${projectedSavings >= 0 ? '+' : ''}${F(projectedSavings)} CHF</span>
    </div>
    ${over ? `<div style="font-size:.68rem;color:var(--red);margin-top:.4rem;">&#9888;&#65039; D&eacute;passement pr&eacute;vu de ${F(projectedTotal - bud)} CHF</div>` : ''}`;
}

// ═══════════ 4. DÉTECTION DOUBLONS ═══════════
function checkDuplicate() {
  const amt = parseFloat(document.getElementById('f-amount')?.value);
  const cat = document.getElementById('f-cat')?.value;
  const date = document.getElementById('f-date')?.value;
  const alertEl = document.getElementById('dupli-alert');
  if (!alertEl || !amt || !date) { if (alertEl) alertEl.style.display = 'none'; return; }
  const dupes = EXP.filter(e => e.amount === amt && e.cat === cat && e.date === date && e.id != document.getElementById('f-edit-id')?.value);
  if (dupes.length > 0) {
    alertEl.style.display = 'block';
    alertEl.innerHTML = `&#9888;&#65039; Doublon possible : ${dupes[0].desc || cat} — ${FD(amt)} CHF le ${date} a d&eacute;j&agrave; &eacute;t&eacute; saisi.`;
    haptic('error');
  } else {
    alertEl.style.display = 'none';
  }
}

